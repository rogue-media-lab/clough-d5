<%# BreadcrumbList — current page path %>
<% if request.path != "/" %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://cloughforsc5.com/"
    }
    <% case controller.action_name %>
    <% when "about" %>
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "About",
      "item": "https://cloughforsc5.com/about"
    }
    <% when "issues" %>
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "Issues",
      "item": "https://cloughforsc5.com/issues"
    }
    <% when "show_issue" %>
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "Issues",
      "item": "https://cloughforsc5.com/issues"
    }
    <% if @issue %>
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": "<%= @issue.title %>",
      "item": "https://cloughforsc5.com/issues/<%= @issue.id %>"
    }
    <% end %>
    <% when "volunteer" %>
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "Volunteer",
      "item": "https://cloughforsc5.com/volunteer"
    }
    <% when "events" %>
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "Events",
      "item": "https://cloughforsc5.com/events"
    }
    <% when "show_event" %>
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "Events",
      "item": "https://cloughforsc5.com/events"
    }
    <% if @event %>
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": "<%= @event.title %>",
      "item": "https://cloughforsc5.com/events/<%= @event.id %>"
    }
    <% end %>
    <% when "news" %>
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "News",
      "item": "https://cloughforsc5.com/news"
    }
    <% end %>
  ]
}
</script>
<% end %>

