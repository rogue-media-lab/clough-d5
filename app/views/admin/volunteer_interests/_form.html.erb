<%= form_with model: [:admin, volunteer_interest], class: "space-y-6" do |f| %>
  <% if volunteer_interest.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md px-4 py-3 text-sm text-red-800">
      <ul class="list-disc list-inside space-y-1">
        <% volunteer_interest.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white rounded-lg border border-ivory-200 p-6 space-y-4">
    <div>
      <%= f.label :name, "Category Name", class: "block text-sm font-medium text-ivory-700 mb-1" %>
      <%= f.text_field :name, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "e.g. Canvassing, Phone Banking, Event Support" %>
    </div>
  </div>

  <div class="flex gap-3">
    <%= f.submit volunteer_interest.persisted? ? "Update Category" : "Create Category", class: "px-4 py-2.5 bg-navy-900 text-white text-sm font-medium rounded-md hover:bg-navy-800 transition-colors cursor-pointer" %>
    <%= link_to "Cancel", admin_volunteer_interests_path, class: "px-4 py-2.5 text-ivory-600 text-sm font-medium hover:text-ivory-800 transition-colors" %>
  </div>
<% end %>
