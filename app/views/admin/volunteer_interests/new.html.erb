<% content_for :title, @interest.new_record? ? "New Interest" : "Edit Interest" %>

<div class="mx-auto md:w-2/3 w-full">
  <h1 class="font-bold text-4xl mb-5"><%= @interest.new_record? ? "New Interest" : "Edit Interest" %></h1>

  <%= render "form", volunteer_interest: @interest %>

  <%= link_to "Back to interests", admin_volunteer_interests_path, class: "ml-auto rounded-md py-3 px-3.5 inline-block font-medium text-gray-500 hover:text-gray-800" %>
</div>