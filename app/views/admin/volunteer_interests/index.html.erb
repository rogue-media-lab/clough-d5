<% content_for :page_title, "Interest Categories" %>

<div class="flex items-center justify-between mb-6">
  <p class="text-sm text-ivory-500"><%= @interests.count %> categories</p>
  <%= link_to "New Category", new_admin_volunteer_interest_path,
        class: "px-4 py-2 bg-navy-900 text-white text-sm font-medium rounded-md hover:bg-navy-800 transition-colors" %>
</div>

<div class="bg-white rounded-lg border border-ivory-200 overflow-hidden">
  <% if @interests.empty? %>
    <p class="px-6 py-8 text-center text-sm text-ivory-400">No interest categories yet. Add some like "Canvassing", "Phone Banking", "Event Support".</p>
  <% else %>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-ivory-100 bg-ivory-50">
          <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Category Name</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Volunteers</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ivory-100">
        <% @interests.each do |interest| %>
          <tr class="hover:bg-ivory-50">
            <td class="px-6 py-4">
              <p class="font-medium text-ivory-900"><%= interest.name %></p>
            </td>
            <td class="px-6 py-4 text-ivory-600 text-sm">
              <%= interest.submissions.count %>
            </td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center gap-2 justify-end">
                <%= link_to "Edit", edit_admin_volunteer_interest_path(interest), class: "text-xs text-navy-900 hover:underline" %>
                <%= link_to "Delete", admin_volunteer_interest_path(interest), data: { turbo_method: :delete, turbo_confirm: "Delete this category?" }, class: "text-xs text-red-600 hover:underline" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
