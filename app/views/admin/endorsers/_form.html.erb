<%= form_with model: [:admin, endorser], class: "space-y-6" do |f| %>
  <% if endorser.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md px-4 py-3 text-sm text-red-800">
      <ul class="list-disc list-inside space-y-1">
        <% endorser.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-3 gap-6">
    <div class="col-span-2 space-y-6">
      <div class="bg-white rounded-lg border border-ivory-200 p-6 space-y-4">
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.text_field :name, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "e.g. John Smith" %>
        </div>
        <div>
          <%= f.label :title, "Title / Role", class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.text_field :title, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "e.g. CEO, Rock Hill Chamber of Commerce" %>
        </div>
        <div>
          <%= f.label :quote, "Endorsement Quote", class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.text_area :quote, rows: 4, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "What they said about Andrew..." %>
        </div>
        <div>
          <%= f.label :photo_url, "Photo URL (optional)", class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.text_field :photo_url, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "https://example.com/photo.jpg" %>
          <p class="text-xs text-ivory-400 mt-1">Paste a URL to the endorser's photo. Leave blank for no photo.</p>
        </div>
      </div>
    </div>

    <div class="space-y-4">
      <div class="bg-white rounded-lg border border-ivory-200 p-6 space-y-4">
        <h3 class="text-sm font-semibold text-ivory-700">Settings</h3>
        <div>
          <%= f.label :category, class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.select :category, Endorser::CATEGORIES.map { |c| [c, c] }, { include_blank: "— Select Category —" }, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400" %>
        </div>
        <div>
          <%= f.label :sort_order, class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.number_field :sort_order, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400" %>
          <p class="text-xs text-ivory-400 mt-1">Lower numbers appear first.</p>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :active, class: "rounded border-ivory-300" %>
          <%= f.label :active, "Visible on site", class: "text-sm text-ivory-700" %>
        </div>
      </div>

      <div class="bg-white rounded-lg border border-ivory-200 p-6">
        <%= f.submit endorser.persisted? ? "Update Endorser" : "Add Endorser", class: "w-full px-4 py-2.5 bg-navy-900 text-white text-sm font-medium rounded-md hover:bg-navy-800 transition-colors cursor-pointer" %>
      </div>
    </div>
  </div>
<% end %>
