<%= form_with model: [:admin, priority], class: "space-y-6" do |f| %>
  <% if priority.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md px-4 py-3 text-sm text-red-800">
      <ul class="list-disc list-inside space-y-1">
        <% priority.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-3 gap-6">
    <div class="col-span-2 space-y-6">
      <div class="bg-white rounded-lg border border-ivory-200 p-6 space-y-4">
        <div>
          <%= f.label :title, class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.text_field :title, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "e.g. Cut costs for working families" %>
        </div>
        <div>
          <%= f.label :description, "Description (optional)", class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.text_area :description, rows: 3, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "Brief explanation shown on the card..." %>
        </div>
      </div>
    </div>

    <div class="space-y-4">
      <div class="bg-white rounded-lg border border-ivory-200 p-6 space-y-4">
        <h3 class="text-sm font-semibold text-ivory-700">Settings</h3>
        <div>
          <%= f.label :position, class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.number_field :position, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400" %>
          <p class="text-xs text-ivory-400 mt-1">Display order (1 = first).</p>
        </div>
        <div>
          <%= f.label :icon, class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.select :icon, Priority::ICONS.map { |k, v| [v, k] }, { include_blank: "— No Icon —" }, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400" %>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :show_icon, class: "rounded border-ivory-300" %>
          <%= f.label :show_icon, "Show icon on card", class: "text-sm text-ivory-700" %>
        </div>
        <div>
          <%= f.label :linked_issue_id, "Link to Issue (optional)", class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.collection_select :linked_issue_id, Issue.active.order(:position), :id, :title, { include_blank: "— No Link —" }, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400" %>
          <p class="text-xs text-ivory-400 mt-1">"Learn More" links to this issue page.</p>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :active, class: "rounded border-ivory-300" %>
          <%= f.label :active, "Visible on site", class: "text-sm text-ivory-700" %>
        </div>
      </div>

      <div class="bg-white rounded-lg border border-ivory-200 p-6">
        <%= f.submit priority.persisted? ? "Update Priority" : "Add Priority", class: "w-full px-4 py-2.5 bg-navy-900 text-white text-sm font-medium rounded-md hover:bg-navy-800 transition-colors cursor-pointer" %>
      </div>
    </div>
  </div>
<% end %>
