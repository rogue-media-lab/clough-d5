<% content_for :page_title, "News Feeds" %>
<% content_for :page_subtitle, "Manage RSS feeds for automatic news import" %>

<div class="grid grid-cols-3 gap-6">
  <div class="col-span-2">
    <div class="bg-white rounded-lg border border-ivory-200 overflow-hidden">
      <% if @feeds.empty? %>
        <p class="px-6 py-8 text-center text-sm text-ivory-400">No feeds added yet.</p>
      <% else %>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-ivory-100 bg-ivory-50">
              <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Name</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">URL</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Active</th>
              <th class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-ivory-100">
            <% @feeds.each do |feed| %>
              <tr class="hover:bg-ivory-50 <%= @feed&.id == feed.id ? 'bg-yellow-50' : '' %>">
                <td class="px-6 py-4 font-medium text-ivory-900"><%= feed.name %></td>
                <td class="px-6 py-4 text-ivory-600 text-xs truncate max-w-xs"><%= feed.url %></td>
                <td class="px-6 py-4">
                  <% if feed.active? %>
                    <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Active</span>
                  <% else %>
                    <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-ivory-100 text-ivory-600">Paused</span>
                  <% end %>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center gap-2 justify-end">
                    <%= link_to "Edit", edit_admin_news_feed_path(feed), class: "text-xs text-navy-900 hover:underline" %>
                    <%= button_to "Delete", admin_news_feed_path(feed), method: :delete, style: "padding: 6px 12px; background: #FEE2E2; color: #DC2626; border-radius: 6px; font-size: 13px; border: none; cursor: pointer; font-weight: 500;", data: { turbo_confirm: "Delete this feed?" } %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  </div>

  <div>
    <div class="bg-white rounded-lg border border-ivory-200 p-6">
      <h3 class="text-sm font-semibold text-ivory-700 mb-4"><%= @feed&.persisted? ? "Edit Feed" : "Add Feed" %></h3>
      <%= form_with model: [:admin, @feed], class: "space-y-4" do |f| %>
        <% if @feed.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-md px-4 py-3 text-sm text-red-800">
            <ul class="list-disc list-inside space-y-1">
              <% @feed.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.text_field :name, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "e.g. Rock Hill Herald" %>
        </div>
        <div>
          <%= f.label :url, "Feed URL", class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.url_field :url, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "https://example.com/feed.rss" %>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :active, class: "rounded border-ivory-300 text-navy-900 focus:ring-navy-400" %>
          <%= f.label :active, "Active", class: "text-sm text-ivory-700" %>
        </div>
        <div class="flex gap-2">
          <%= f.submit @feed&.persisted? ? "Update Feed" : "Add Feed", class: "flex-1 px-4 py-2 bg-navy-900 text-white text-sm font-medium rounded-md hover:bg-navy-800 transition-colors cursor-pointer" %>
          <% if @feed&.persisted? %>
            <%= link_to "Cancel", admin_news_feeds_path, class: "px-4 py-2 bg-ivory-100 text-ivory-700 text-sm font-medium rounded-md hover:bg-ivory-200 transition-colors" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
