<% content_for :page_title, @message.subject %>
<% content_for :page_subtitle, "From #{@message.name} (#{@message.email})" %>

<div class="max-w-3xl">
  <div class="bg-white rounded-lg border border-ivory-200 p-6 space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-xs font-semibold text-ivory-500 uppercase mb-1">From</p>
        <p class="text-ivory-900 font-medium"><%= @message.name %></p>
        <p class="text-ivory-600 text-sm"><a href="mailto:<%= @message.email %>" class="text-campaign-gold hover:underline"><%= @message.email %></a></p>
      </div>
      <div class="text-right">
        <p class="text-xs font-semibold text-ivory-500 uppercase mb-1">Received</p>
        <p class="text-ivory-700 text-sm"><%= @message.created_at.strftime("%B %-d, %Y at %l:%M %p") %></p>
      </div>
    </div>

    <div>
      <p class="text-xs font-semibold text-ivory-500 uppercase mb-1">Subject</p>
      <p class="text-ivory-900 font-medium"><%= @message.subject %></p>
    </div>

    <div class="border-t border-ivory-200 pt-6">
      <p class="text-ivory-800 font-sans text-base leading-relaxed whitespace-pre-wrap"><%= @message.body %></p>
    </div>
  </div>

  <div class="flex gap-3 mt-6">
    <a href="mailto:<%= @message.email %>?subject=Re: <%= @message.subject %>" target="_blank" rel="noopener" class="px-4 py-2 bg-navy-900 text-white text-sm font-medium rounded-md hover:bg-navy-800 transition-colors" onclick="fetch('<%= mark_replied_admin_contact_message_path(@message) %>', {method: 'POST', headers: {'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content}})">
      Reply via Email
    </a>
    <% if @message.unread? || @message.read? %>
      <%= button_to "Mark as Replied", mark_replied_admin_contact_message_path(@message), class: "px-4 py-2 border border-ivory-300 text-ivory-700 text-sm font-medium rounded-md hover:bg-ivory-50 transition-colors cursor-pointer" %>
    <% end %>
    <%= link_to "Back to Messages", admin_contact_messages_path, class: "px-4 py-2 border border-ivory-300 text-ivory-700 text-sm font-medium rounded-md hover:bg-ivory-50 transition-colors" %>
  </div>
</div>
