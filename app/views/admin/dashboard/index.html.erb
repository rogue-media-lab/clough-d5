<% content_for :page_title, "Dashboard" %>
<% content_for :page_subtitle, "Welcome back. Here's what's happening." %>

<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 32px;">
    <div style="background-color: #FFFFFF; border-radius: 8px; border: 1px solid #E5E7EB; padding: 24px;">
        <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 500; color: #6B7280; text-transform: uppercase;">Total Issues</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; color: #0F2044;"><%= @issue_count %></p>
    </div>
    <div style="background-color: #FFFFFF; border-radius: 8px; border: 1px solid #E5E7EB; padding: 24px;">
        <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 500; color: #6B7280; text-transform: uppercase;">Active Issues</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; color: #16A34A;"><%= @active_issue_count %></p>
    </div>
    <div style="background-color: #FFFFFF; border-radius: 8px; border: 1px solid #E5E7EB; padding: 24px;">
        <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 500; color: #6B7280; text-transform: uppercase;">Total Posts</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; color: #0F2044;"><%= @post_count %></p>
    </div>
    <div style="background-color: #FFFFFF; border-radius: 8px; border: 1px solid #E5E7EB; padding: 24px;">
        <p style="font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 500; color: #6B7280; text-transform: uppercase;">Draft Posts</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; color: #CA8A04;"><%= @draft_count %></p>
    </div>
</div>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
    <div style="background-color: #FFFFFF; border-radius: 8px; border: 1px solid #E5E7EB;">
        <div style="padding: 16px 24px; border-bottom: 1px solid #E5E7EB; display: flex; justify-content: space-between; align-items: center;">
            <h2 style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; color: #374151;">Recent Issues</h2>
            <%= link_to "View all", admin_issues_path, style: "font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280; text-decoration: none;" %>
        </div>
        <div>
            <% @recent_issues.each do |issue| %>
            <div style="padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #E5E7EB;">
                <div>
                    <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; color: #111827;"><%= issue.title %></p>
                    <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280;"><%= issue.status %>, <%= issue.featured? ? 'Featured' : 'Not Featured' %></p>
                </div>
                <%= link_to "Edit", edit_admin_issue_path(issue), style: "font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280; text-decoration: none;" %>
            </div>
            <% end %>
        </div>
    </div>
    <div style="background-color: #FFFFFF; border-radius: 8px; border: 1px solid #E5E7EB;">
        <div style="padding: 16px 24px; border-bottom: 1px solid #E5E7EB; display: flex; justify-content: space-between; align-items: center;">
            <h2 style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; color: #374151;">Recent Posts</h2>
            <%= link_to "View all", admin_posts_path, style: "font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280; text-decoration: none;" %>
        </div>
        <div>
            <% @recent_posts.each do |post| %>
            <div style="padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #E5E7EB;">
                <div>
                    <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; color: #111827;"><%= post.title %></p>
                    <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280;"><%= post.published? ? "Published on #{post.published_at.strftime('%b %-d, %Y')}" : "Draft" %></p>
                </div>
                <%= link_to "Edit", edit_admin_post_path(post), style: "font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280; text-decoration: none;" %>
            </div>
            <% end %>
        </div>
    </div>
</div>
