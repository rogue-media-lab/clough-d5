<% content_for :page_title, "Dashboard" %>
<% content_for :page_subtitle, "Welcome back. Here's what's happening." %>

<!-- Stats Row -->
<div style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; margin-bottom: 32px;">
  <div class="stat-card">
    <p class="stat-label">Active Issues</p>
    <p class="stat-value" style="color: #16A34A;"><%= @active_issue_count %></p>
    <p style="font-size: 12px; color: #9CA3AF; margin: 4px 0 0;"><%= @issue_count %> total</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">News Articles</p>
    <p class="stat-value" style="color: #2563EB;"><%= @published_news_count %></p>
    <p style="font-size: 12px; color: #9CA3AF; margin: 4px 0 0;"><%= @fetched_news_count %> fetched</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Total Volunteers</p>
    <p class="stat-value"><%= @volunteer_count %></p>
    <p style="font-size: 12px; color: #16A34A; margin: 4px 0 0;"><%= @new_this_week %> new this week</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Pending Review</p>
    <p class="stat-value" style="color: #D97706;"><%= @pending_count %></p>
    <p style="font-size: 12px; color: #9CA3AF; margin: 4px 0 0;">awaiting response</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Confirmed</p>
    <p class="stat-value" style="color: #16A34A;"><%= @confirmed_count %></p>
    <p style="font-size: 12px; color: #9CA3AF; margin: 4px 0 0;">ready to go</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Upcoming Events</p>
    <p class="stat-value" style="color: #7C3AED;"><%= @upcoming_count %></p>
    <p style="font-size: 12px; color: #9CA3AF; margin: 4px 0 0;"><%= @event_count %> total</p>
  </div>
</div>

<!-- Two Column Layout -->
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">

  <!-- Recent Volunteers -->
  <div class="widget-card">
    <div class="widget-header">
      <h2 class="widget-title">Recent Volunteers</h2>
      <%= link_to "View all", admin_volunteer_submissions_path, class: "widget-link" %>
    </div>
    <div>
      <% @recent_volunteers.each do |volunteer| %>
        <div class="widget-row">
          <div>
            <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; color: #111827; margin: 0;"><%= volunteer.name %></p>
            <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280; margin: 2px 0 0;">
              <%= volunteer.area_code.presence || "No area" %> · <%= time_ago_in_words(volunteer.created_at) %> ago
            </p>
          </div>
          <span class="badge badge-<%= volunteer.submission_status %>"><%= volunteer.submission_status %></span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent Issues -->
  <div class="widget-card">
    <div class="widget-header">
      <h2 class="widget-title">Recent Issues</h2>
      <%= link_to "View all", admin_issues_path, class: "widget-link" %>
    </div>
    <div>
      <% @recent_issues.each do |issue| %>
        <div class="widget-row">
          <div>
            <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; color: #111827; margin: 0;"><%= issue.title %></p>
            <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280; margin: 2px 0 0;"><%= issue.status %> <%= issue.featured? ? "· Featured" : "" %></p>
          </div>
          <%= link_to "Edit", edit_admin_issue_path(issue), class: "widget-link" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Interest Breakdown -->
  <div class="widget-card">
    <div class="widget-header">
      <h2 class="widget-title">Volunteers by Interest</h2>
      <%= link_to "Manage", admin_volunteer_interests_path, class: "widget-link" %>
    </div>
    <div style="padding: 16px 20px;">
      <% @interest_breakdown.each do |name, count| %>
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;">
          <span style="font-size: 14px; color: #374151;"><%= name %></span>
          <div style="display: flex; align-items: center; gap: 10px;">
            <div style="width: 120px; height: 6px; background: #F3F4F6; border-radius: 3px; overflow: hidden;">
              <div style="width: <%= (count.to_f / @volunteer_count * 100).round %>%; height: 100%; background: #C8902A; border-radius: 3px;"></div>
            </div>
            <span style="font-size: 13px; font-weight: 600; color: #0F2044; min-width: 20px; text-align: right;"><%= count %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Blog Posts -->
  <div class="widget-card">
    <div class="widget-header">
      <h2 class="widget-title">Blog Posts</h2>
      <%= link_to "View all", admin_posts_path, class: "widget-link" %>
    </div>
    <div>
      <% @recent_posts.each do |post| %>
        <div class="widget-row">
          <div>
            <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; color: #111827; margin: 0;"><%= post.title %></p>
            <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280; margin: 2px 0 0;">
              <%= post.published? ? "Published #{post.published_at.strftime('%b %-d')}" : "Draft" %>
            </p>
          </div>
          <%= link_to "Edit", edit_admin_post_path(post), class: "widget-link" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent News Articles -->
  <div class="widget-card">
    <div class="widget-header">
      <h2 class="widget-title">News Articles</h2>
      <%= link_to "View all", admin_news_articles_path, class: "widget-link" %>
    </div>
    <div>
      <% @recent_articles.each do |article| %>
        <div class="widget-row">
          <div>
            <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; color: #111827; margin: 0;"><%= article.title %></p>
            <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280; margin: 2px 0 0;">
              <%= article.source %> · <%= article.published? ? "Published" : "Draft" %>
            </p>
          </div>
          <%= link_to "Edit", edit_admin_news_article_path(article), class: "widget-link" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# This Week's Events %>
  <div class="widget-card">
    <div class="widget-header">
      <h2 class="widget-title">This Week's Events</h2>
      <%= link_to "View all", admin_events_path, class: "widget-link" %>
    </div>
    <div>
      <% if @this_week_events.any? %>
        <% @this_week_events.each do |event| %>
          <div class="widget-row">
            <div>
              <p style="font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; color: #111827; margin: 0;"><%= event.title %></p>
              <p style="font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280; margin: 2px 0 0;">
                <%= event.date.strftime("%a, %b %-d at %l:%M %p") %> · <%= event.location %>
              </p>
            </div>
            <%= link_to "Edit", edit_admin_event_path(event), class: "widget-link" %>
          </div>
        <% end %>
      <% else %>
        <p style="padding: 20px; text-align: center; font-size: 13px; color: #9CA3AF;">No events this week.</p>
      <% end %>
    </div>
  </div>

</div>
