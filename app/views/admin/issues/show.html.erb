<% content_for :title, "Showing issue" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="bg-white shadow rounded-lg p-6 mb-6">
    <div class="flex items-center gap-4 mb-4">
      <span class="text-4xl"><%= @issue.icon %></span>
      <div>
        <h1 class="font-bold text-2xl"><%= @issue.title %></h1>
        <p class="text-sm text-gray-500 mt-1">
          Status: <%= @issue.status %> | Featured: <%= @issue.featured? ? "Yes" : "No" %> | Position: <%= @issue.position %>
        </p>
      </div>
    </div>
    <div class="prose max-w-none">
      <%= @issue.description %>
    </div>
  </div>

  <%= link_to "Edit this issue", edit_admin_issue_path(@issue), class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium" %>
  <%= link_to "Back to issues", admin_issues_path, class: "rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium ml-2" %>
</div>
