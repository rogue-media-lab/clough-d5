<% content_for :title, "Issues" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Issues</h1>
    <%= link_to "New issue", new_admin_issue_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div id="issues" class="min-w-full divide-y divide-gray-200 space-y-5">
    <% if @issues.any? %>
      <% @issues.each do |issue| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <div class="w-full">
            <div class="flex items-center gap-4">
              <span class="text-2xl"><%= issue.icon %></span>
              <div>
                <h3 class="text-lg font-medium text-gray-900"><%= issue.title %></h3>
                <p class="text-sm text-gray-500">Position: <%= issue.position %> | Status: <%= issue.status %> | Featured: <%= issue.featured? ? "Yes" : "No" %></p>
              </div>
            </div>
          </div>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", admin_issue_path(issue), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
            <%= link_to "Edit", edit_admin_issue_path(issue), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
            <%= button_to "Destroy", admin_issue_path(issue), method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No issues found.</p>
    <% end %>
  </div>
</div>
