<% content_for :page_title, @event.title %>

<div class="mb-6">
  <%= link_to "← Back to events", admin_events_path, class: "text-sm text-ivory-500 hover:text-ivory-700" %>
</div>

<div class="grid grid-cols-3 gap-6">
  <div class="col-span-2">
    <div class="bg-white rounded-lg border border-ivory-200 p-6">
      <h1 class="text-2xl font-bold text-ivory-900 mb-4"><%= @event.title %></h1>
      <div class="flex items-center gap-4 text-sm text-ivory-500 mb-6">
        <span><%= @event.date.strftime("%B %-d, %Y at %l:%M %p") %></span>
        <span>&middot;</span>
        <span><%= @event.location %></span>
      </div>
      <% if @event.description.present? %>
        <div class="prose prose-sm max-w-none text-ivory-700">
          <%= @event.description %>
        </div>
      <% end %>

      <% if @event.has_coordinates? %>
        <div class="mt-6">
          <h3 class="text-sm font-semibold text-ivory-700 mb-3">Event Location</h3>
          <div id="admin-event-map" class="rounded-lg border border-ivory-200" style="height: 250px;"></div>
        </div>
        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
          document.addEventListener("DOMContentLoaded", function() {
            var map = L.map('admin-event-map').setView([<%= @event.latitude %>, <%= @event.longitude %>], 15);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
              attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);
            L.marker([<%= @event.latitude %>, <%= @event.longitude %>]).addTo(map)
              .bindPopup('<%= j @event.title %>');
          });
        </script>
      <% end %>
    </div>
  </div>
  <div class="space-y-4">
    <div class="bg-white rounded-lg border border-ivory-200 p-6">
      <h3 class="text-sm font-semibold text-ivory-700 mb-3">Details</h3>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-ivory-500">Status</dt>
          <dd><%= @event.status.capitalize %></dd>
        </div>
        <% if @event.has_coordinates? %>
          <div class="flex justify-between">
            <dt class="text-ivory-500">Coordinates</dt>
            <dd class="text-xs"><%= @event.latitude %>, <%= @event.longitude %></dd>
          </div>
        <% end %>
        <% if @event.google_event_id.present? %>
          <div class="flex justify-between">
            <dt class="text-ivory-500">Google Event</dt>
            <dd class="text-green-600 text-xs">Synced</dd>
          </div>
        <% end %>
      </dl>
    </div>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_admin_event_path(@event), class: "flex-1 text-center px-4 py-2 bg-navy-900 text-white text-sm font-medium rounded-md hover:bg-navy-800 transition-colors" %>
      <%= link_to "Delete", admin_event_path(@event), data: { turbo_method: :delete, turbo_confirm: "Delete this event?" }, class: "px-4 py-2 bg-red-50 text-red-700 text-sm font-medium rounded-md hover:bg-red-100 transition-colors" %>
    </div>
  </div>
</div>
