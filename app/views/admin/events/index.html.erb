<% content_for :page_title, "Events" %>

<div class="flex items-center justify-between mb-6">
  <p class="text-sm text-ivory-500"><%= @upcoming.count %> upcoming</p>
  <%= link_to "New Event", new_admin_event_path,
        class: "px-4 py-2 bg-navy-900 text-white text-sm font-medium rounded-md hover:bg-navy-800 transition-colors" %>
</div>

<%# Upcoming Events %>
<div class="mb-8">
  <h2 class="text-sm font-semibold text-ivory-700 uppercase tracking-wider mb-4">Upcoming</h2>
  <div class="bg-white rounded-lg border border-ivory-200 overflow-hidden">
    <% if @upcoming.empty? %>
      <p class="px-6 py-8 text-center text-sm text-ivory-400">No upcoming events.</p>
    <% else %>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-ivory-100 bg-ivory-50">
            <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Title</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Location</th>
            <th class="px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-ivory-100">
          <% @upcoming.each do |event| %>
            <tr class="hover:bg-ivory-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="bg-navy-900 rounded px-2 py-1 inline-flex flex-col items-center">
                  <span class="text-campaign-gold text-[10px] font-bold uppercase"><%= event.date.strftime("%b") %></span>
                  <span class="text-white font-bold text-lg leading-none"><%= event.date.strftime("%-d") %></span>
                </div>
              </td>
              <td class="px-6 py-4">
                <p class="font-medium text-ivory-900"><%= event.title %></p>
                <p class="text-xs text-ivory-400 mt-0.5"><%= event.date.strftime("%l:%M %p") %></p>
              </td>
              <td class="px-6 py-4 text-ivory-600 text-sm"><%= event.location %></td>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center gap-2 justify-end">
                  <%= link_to "Edit", edit_admin_event_path(event), class: "text-xs text-navy-900 hover:underline" %>
                  <%= button_to "Delete", admin_event_path(event), method: :delete, style: "padding: 6px 12px; background: #FEE2E2; color: #DC2626; border-radius: 6px; font-size: 13px; border: none; cursor: pointer; font-weight: 500;", data: { turbo_confirm: "Delete this event?" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>

<%# Past Events %>
<div>
  <h2 class="text-sm font-semibold text-ivory-700 uppercase tracking-wider mb-4">Past Events</h2>
  <div class="bg-white rounded-lg border border-ivory-200 overflow-hidden">
    <% if @past.empty? %>
      <p class="px-6 py-8 text-center text-sm text-ivory-400">No past events.</p>
    <% else %>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-ivory-100 bg-ivory-50">
            <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Date</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Title</th>
            <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Location</th>
            <th class="px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-ivory-100">
          <% @past.each do |event| %>
            <tr class="hover:bg-ivory-50 opacity-70">
              <td class="px-6 py-4 whitespace-nowrap text-ivory-400 text-sm"><%= event.date.strftime("%b %-d, %Y") %></td>
              <td class="px-6 py-4 text-ivory-600"><%= event.title %></td>
              <td class="px-6 py-4 text-ivory-400 text-sm"><%= event.location %></td>
              <td class="px-6 py-4 text-right">
                <%= link_to "Edit", edit_admin_event_path(event), class: "text-xs text-navy-900 hover:underline" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
