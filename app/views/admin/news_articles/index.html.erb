<% content_for :page_title, "News Articles" %>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3">
    <p class="text-sm text-ivory-500"><%= @articles.count %> articles</p>
    <div class="flex gap-2">
      <%= link_to "All", admin_news_articles_path,
            class: "px-3 py-1 text-xs rounded-full #{params[:status].blank? && params[:source].blank? ? 'bg-navy-900 text-white' : 'bg-ivory-100 text-ivory-600 hover:bg-ivory-200'}" %>
      <%= link_to "Published", admin_news_articles_path(status: :published),
            class: "px-3 py-1 text-xs rounded-full #{params[:status] == 'published' ? 'bg-navy-900 text-white' : 'bg-ivory-100 text-ivory-600 hover:bg-ivory-200'}" %>
      <%= link_to "Fetched", admin_news_articles_path(status: :fetched),
            class: "px-3 py-1 text-xs rounded-full #{params[:status] == 'fetched' ? 'bg-navy-900 text-white' : 'bg-ivory-100 text-ivory-600 hover:bg-ivory-200'}" %>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <%= button_to "Fetch News", fetch_feeds_admin_news_articles_path,
          method: :post,
          class: "px-4 py-2 bg-campaign-gold text-white text-sm font-medium rounded-md hover:bg-campaign-gold-dark transition-colors cursor-pointer border-0",
          data: { turbo_confirm: "Fetch new articles from all active RSS feeds?" } %>
    <%= link_to "New Article", new_admin_news_article_path,
          class: "px-4 py-2 bg-navy-900 text-white text-sm font-medium rounded-md hover:bg-navy-800 transition-colors" %>
  </div>
</div>

<%# Source filter dropdown %>
<% if @sources.any? %>
  <div class="mb-4 flex items-center gap-2">
    <span class="text-xs text-ivory-500">Source:</span>
    <%= link_to "All Sources", admin_news_articles_path(status: params[:status]),
          class: "px-2 py-1 text-xs rounded #{params[:source].blank? ? 'bg-ivory-200 font-semibold' : 'text-ivory-500 hover:text-ivory-700'}" %>
    <% @sources.each do |src| %>
      <%= link_to src, admin_news_articles_path(status: params[:status], source: src),
            class: "px-2 py-1 text-xs rounded #{params[:source] == src ? 'bg-ivory-200 font-semibold' : 'text-ivory-500 hover:text-ivory-700'}" %>
    <% end %>
  </div>
<% end %>

<%= form_tag bulk_publish_admin_news_articles_path, method: :patch, id: "bulk-form" do %>
  <%# Bulk action bar %>
  <div id="bulk-bar" class="hidden mb-4 bg-navy-900 text-white rounded-lg px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="text-sm"><span id="selected-count">0</span> selected</span>
      <button type="button" onclick="clearSelection()" class="text-xs text-slate-400 hover:text-white">Clear</button>
    </div>
    <div class="flex gap-2">
      <button type="submit" formaction="<%= bulk_publish_admin_news_articles_path %>" class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs font-medium rounded cursor-pointer border-0">Publish Selected</button>
      <button type="submit" formaction="<%= bulk_unpublish_admin_news_articles_path %>" class="px-3 py-1.5 bg-yellow-600 hover:bg-yellow-700 text-white text-xs font-medium rounded cursor-pointer border-0">Unpublish Selected</button>
      <button type="submit" formaction="<%= bulk_delete_admin_news_articles_path %>" data-turbo-confirm="Delete selected articles?" class="px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white text-xs font-medium rounded cursor-pointer border-0">Delete Selected</button>
    </div>
  </div>

  <div class="bg-white rounded-lg border border-ivory-200 overflow-hidden">
    <% if @articles.empty? %>
      <p class="px-6 py-8 text-center text-sm text-ivory-400">No articles yet. Click "Fetch News" to pull from RSS feeds.</p>
    <% else %>
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-ivory-100 bg-ivory-50">
            <th class="px-4 py-3 w-10"><input type="checkbox" id="select-all" onclick="toggleAll()" class="rounded border-ivory-300"></th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Title</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Source</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Status</th>
            <th class="px-4 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Date</th>
            <th class="px-4 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-ivory-100">
          <% @articles.each do |article| %>
            <tr class="hover:bg-ivory-50">
              <td class="px-4 py-3"><input type="checkbox" name="article_ids[]" value="<%= article.id %>" class="article-checkbox rounded border-ivory-300" onchange="updateBulkBar()"></td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-3">
                  <% if article.image.present? %>
                    <img src="<%= article.image %>" alt="" class="w-12 h-8 object-cover rounded flex-shrink-0">
                  <% else %>
                    <div class="w-12 h-8 bg-ivory-100 rounded flex items-center justify-center flex-shrink-0">
                      <span class="text-xs text-ivory-400">&#9679;</span>
                    </div>
                  <% end %>
                  <div>
                    <p class="font-medium text-ivory-900"><%= article.title.truncate(80) %></p>
                    <% if article.external_url.present? %>
                      <p class="text-xs text-ivory-400 mt-0.5 truncate max-w-md"><%= article.external_url %></p>
                    <% end %>
                  </div>
                </div>
              </td>
              <td class="px-4 py-3 text-ivory-600 text-xs"><%= article.source %></td>
              <td class="px-4 py-3">
                <% if article.published? %>
                  <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Published</span>
                <% else %>
                  <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-ivory-100 text-ivory-600">Fetched</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-xs text-ivory-400">
                <%= article.published_date&.strftime("%b %d") || "—" %>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex items-center gap-2 justify-end">
                  <% if article.fetched? %>
                    <%= link_to "Publish", admin_news_article_path(article, news_article: { status: :published }), data: { turbo_method: :patch }, class: "text-xs text-green-700 hover:underline" %>
                  <% else %>
                    <%= link_to "Unpublish", admin_news_article_path(article, news_article: { status: :fetched }), data: { turbo_method: :patch }, class: "text-xs text-yellow-700 hover:underline" %>
                  <% end %>
                  <%= link_to "Edit", edit_admin_news_article_path(article), class: "text-xs text-ivory-600 hover:text-ivory-900 hover:underline" %>
                  <%= button_to "Delete", admin_news_article_path(article), method: :delete, style: "padding: 6px 12px; background: #FEE2E2; color: #DC2626; border-radius: 6px; font-size: 13px; border: none; cursor: pointer; font-weight: 500;", data: { turbo_confirm: "Delete this article?" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
<% end %>

<script>
  function toggleAll() {
    const checked = document.getElementById('select-all').checked;
    document.querySelectorAll('.article-checkbox').forEach(cb => cb.checked = checked);
    updateBulkBar();
  }

  function updateBulkBar() {
    const checked = document.querySelectorAll('.article-checkbox:checked').length;
    const bar = document.getElementById('bulk-bar');
    const count = document.getElementById('selected-count');
    if (checked > 0) {
      bar.classList.remove('hidden');
      bar.classList.add('flex');
      count.textContent = checked;
    } else {
      bar.classList.add('hidden');
      bar.classList.remove('flex');
    }
  }

  function clearSelection() {
    document.querySelectorAll('.article-checkbox').forEach(cb => cb.checked = false);
    document.getElementById('select-all').checked = false;
    updateBulkBar();
  }
</script>
