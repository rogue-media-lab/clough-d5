<% content_for :page_title, "News Articles" %>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3">
    <p class="text-sm text-ivory-500"><%= @articles.count %> articles</p>
    <div class="flex gap-2">
      <%= link_to "All", admin_news_articles_path,
            class: "px-3 py-1 text-xs rounded-full #{params[:status].blank? ? 'bg-navy-900 text-white' : 'bg-ivory-100 text-ivory-600 hover:bg-ivory-200'}" %>
      <%= link_to "Published", admin_news_articles_path(status: :published),
            class: "px-3 py-1 text-xs rounded-full #{params[:status] == 'published' ? 'bg-navy-900 text-white' : 'bg-ivory-100 text-ivory-600 hover:bg-ivory-200'}" %>
      <%= link_to "Drafts", admin_news_articles_path(status: :draft),
            class: "px-3 py-1 text-xs rounded-full #{params[:status] == 'draft' ? 'bg-navy-900 text-white' : 'bg-ivory-100 text-ivory-600 hover:bg-ivory-200'}" %>
    </div>
  </div>
  <%= link_to "New Article", new_admin_news_article_path,
        class: "px-4 py-2 bg-navy-900 text-white text-sm font-medium rounded-md hover:bg-navy-800 transition-colors" %>
</div>

<div class="bg-white rounded-lg border border-ivory-200 overflow-hidden">
  <% if @articles.empty? %>
    <p class="px-6 py-8 text-center text-sm text-ivory-400">No articles yet.</p>
  <% else %>
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-ivory-100 bg-ivory-50">
          <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Title</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Source</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Featured</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-ivory-500 uppercase tracking-wider">Date</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-ivory-100">
        <% @articles.each do |article| %>
          <tr class="hover:bg-ivory-50">
            <td class="px-6 py-4">
              <p class="font-medium text-ivory-900"><%= article.title %></p>
              <% if article.external_url.present? %>
                <p class="text-xs text-ivory-400 mt-0.5 truncate max-w-xs"><%= article.external_url %></p>
              <% end %>
            </td>
            <td class="px-6 py-4 text-ivory-600 text-sm"><%= article.source %></td>
            <td class="px-6 py-4">
              <% if article.published? %>
                <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Published</span>
              <% else %>
                <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Draft</span>
              <% end %>
            </td>
            <td class="px-6 py-4">
              <% if article.featured? %>
                <span class="text-campaign-gold">&#9733;</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-xs text-ivory-400">
              <%= article.published_date&.strftime("%b %d, %Y") || "—" %>
            </td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center gap-2 justify-end">
                <%= link_to "Edit", edit_admin_news_article_path(article), class: "text-xs text-navy-900 hover:underline" %>
                <%= link_to "Delete", admin_news_article_path(article), data: { turbo_method: :delete, turbo_confirm: "Delete this article?" }, class: "text-xs text-red-600 hover:underline" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
