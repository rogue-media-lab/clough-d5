<%= form_with model: [:admin, article], class: "space-y-6" do |f| %>
  <% if article.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md px-4 py-3 text-sm text-red-800">
      <ul class="list-disc list-inside space-y-1">
        <% article.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-3 gap-6">
    <%# Main content column %>
    <div class="col-span-2 space-y-6">
      <div class="bg-white rounded-lg border border-ivory-200 p-6 space-y-4">
        <div>
          <%= f.label :title, class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.text_field :title, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400" %>
        </div>
        <div>
          <%= f.label :body, "Summary / Notes", class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.text_area :body, rows: 6, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "Optional summary or notes about this article..." %>
        </div>
      </div>

      <div class="bg-white rounded-lg border border-ivory-200 p-6 space-y-4">
        <h3 class="text-sm font-semibold text-ivory-700">External Link</h3>
        <div>
          <%= f.label :external_url, "URL", class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.url_field :external_url, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "https://example.com/article" %>
        </div>
      </div>
    </div>

    <%# Sidebar column %>
    <div class="space-y-4">
      <div class="bg-white rounded-lg border border-ivory-200 p-6 space-y-4">
        <h3 class="text-sm font-semibold text-ivory-700">Publishing</h3>
        <div>
          <%= f.label :status, class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.select :status, [["Draft", :draft], ["Published", :published]], {}, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400" %>
        </div>
        <div>
          <%= f.label :published_date, "Published date", class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.datetime_field :published_date, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400" %>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :featured, class: "rounded border-ivory-300 text-navy-900 focus:ring-navy-400" %>
          <%= f.label :featured, "Featured article", class: "text-sm text-ivory-700" %>
        </div>
      </div>

      <div class="bg-white rounded-lg border border-ivory-200 p-6 space-y-4">
        <h3 class="text-sm font-semibold text-ivory-700">Source</h3>
        <div>
          <%= f.label :source, "Source name", class: "block text-sm font-medium text-ivory-700 mb-1" %>
          <%= f.text_field :source, class: "w-full border border-ivory-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-navy-400", placeholder: "e.g. Rock Hill Herald" %>
        </div>
      </div>

      <div class="bg-white rounded-lg border border-ivory-200 p-6">
        <%= f.submit article.persisted? ? "Update Article" : "Create Article", class: "w-full px-4 py-2 bg-navy-900 text-white text-sm font-medium rounded-md hover:bg-navy-800 transition-colors cursor-pointer" %>
      </div>
    </div>
  </div>
<% end %>
