<% content_for :title, "Volunteer Submissions" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Volunteer Submissions</h1>
  </div>

  <div id="submissions" class="min-w-full divide-y divide-gray-200 space-y-5 mt-5">
    <% if @submissions.any? %>
      <% @submissions.each do |submission| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <div class="w-full">
            <div>
              <h3 class="text-lg font-medium text-gray-900"><%= submission.name %></h3>
              <p class="text-sm text-gray-500"><%= submission.email %> | <%= submission.phone.presence || "No phone" %></p>
              <p class="text-sm text-gray-500">Area: <%= submission.area_code.presence || "Not provided" %> | Status: <%= submission.submission_status %></p>
              <% if submission.interests.any? %>
                <p class="text-sm text-gray-500 mt-1">Interests: <%= submission.interests.pluck(:name).join(", ") %></p>
              <% end %>
            </div>
          </div>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "Show", admin_volunteer_submission_path(submission), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
            <%= button_to "Destroy", admin_volunteer_submission_path(submission), method: :delete, class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No volunteer submissions yet.</p>
    <% end %>
  </div>
</div>