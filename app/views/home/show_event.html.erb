<% content_for :title, "#{@event.title} - Clough for SC5" %>

<%# Hero Section %>
<section class="bg-navy-900 w-full">
  <div class="max-w-7xl mx-auto px-6 py-16 lg:px-20 lg:py-20 flex flex-col gap-5">
    <div class="flex items-center gap-3">
      <div class="bg-campaign-gold h-0.5 w-10"></div>
      <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.1em] uppercase">Event Details</span>
    </div>
    <h1 class="text-white font-display text-4xl sm:text-5xl lg:text-[56px] font-bold leading-[1.1]"><%= @event.title %></h1>
  </div>
</section>

<%# Event Content %>
<section class="bg-ivory-50 w-full">
  <div class="max-w-7xl mx-auto px-6 py-16 lg:px-20 lg:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <%# Event Details Column %>
      <div class="lg:col-span-2 flex flex-col gap-6">
        <div class="bg-white rounded-xl border border-ivory-200 p-8">
          <div class="flex items-center gap-6 mb-8">
            <div class="bg-navy-900 rounded-lg px-5 py-4 flex flex-col items-center">
              <span class="text-campaign-gold font-sans text-xs font-bold tracking-[0.1em] uppercase"><%= @event.date.strftime("%b") %></span>
              <span class="text-white font-display text-5xl font-bold leading-none"><%= @event.date.strftime("%-d") %></span>
              <span class="text-slate-400 font-sans text-xs"><%= @event.date.strftime("%A") %></span>
            </div>
            <div>
              <p class="text-navy-900 font-sans text-lg font-semibold"><%= @event.date.strftime("%B %-d, %Y") %></p>
              <p class="text-gray-500 font-sans text-base"><%= @event.date.strftime("%l:%M %p") %> local time</p>
            </div>
          </div>

          <div class="flex items-start gap-3 mb-6 pb-6 border-b border-ivory-200">
            <svg class="w-5 h-5 text-gray-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <div>
              <p class="text-navy-900 font-sans text-base font-medium"><%= @event.location %></p>
            </div>
          </div>

          <% if @event.description.present? %>
            <div class="prose prose-lg max-w-none text-gray-700 font-sans leading-relaxed">
              <%= simple_format(@event.description) %>
            </div>
          <% end %>
        </div>

        <%# Map Section %>
        <% if @event.has_coordinates? %>
          <div class="bg-white rounded-xl border border-ivory-200 p-8">
            <h2 class="text-navy-900 font-display text-2xl font-bold mb-4">Event Location</h2>
            <div id="event-map" class="rounded-lg border border-ivory-200" style="height: 400px;"></div>
            <div class="mt-4 flex gap-3">
              <a href="<%= @event.directions_url %>" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 bg-campaign-gold text-navy-900 text-sm font-medium rounded-md hover:bg-campaign-gold/90 transition-colors">
                Get Directions
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            </div>
          </div>
          <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
          <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
          <script>
            document.addEventListener("DOMContentLoaded", function() {
              var map = L.map('event-map').setView([<%= @event.latitude %>, <%= @event.longitude %>], 15);
              L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
              }).addTo(map);
              L.marker([<%= @event.latitude %>, <%= @event.longitude %>]).addTo(map)
                .bindPopup('<strong><%= j @event.title %></strong><br><%= j @event.location %>')
                .openPopup();
            });
          </script>
        <% end %>
      </div>

      <%# Sidebar %>
      <div class="flex flex-col gap-4">
        <div class="bg-white rounded-xl border border-ivory-200 p-6">
          <h3 class="text-navy-900 font-display text-lg font-bold mb-4">Event Info</h3>
          <dl class="space-y-3 text-sm">
            <div>
              <dt class="text-gray-500 font-sans">Date</dt>
              <dd class="text-navy-900 font-sans font-medium"><%= @event.date.strftime("%B %-d, %Y") %></dd>
            </div>
            <div>
              <dt class="text-gray-500 font-sans">Time</dt>
              <dd class="text-navy-900 font-sans font-medium"><%= @event.date.strftime("%l:%M %p") %></dd>
            </div>
            <div>
              <dt class="text-gray-500 font-sans">Location</dt>
              <dd class="text-navy-900 font-sans font-medium"><%= @event.location %></dd>
            </div>
            <div>
              <dt class="text-gray-500 font-sans">Status</dt>
              <dd>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= @event.upcoming? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                  <%= @event.status.capitalize %>
                </span>
              </dd>
            </div>
          </dl>
        </div>

        <div class="bg-navy-900 rounded-xl p-6">
          <h3 class="text-white font-display text-lg font-bold mb-2">Want to help?</h3>
          <p class="text-white/70 font-sans text-sm mb-4">Join our volunteer team to support events like this.</p>
          <%= link_to "Volunteer Now", volunteer_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-campaign-gold text-navy-900 text-sm font-medium rounded-md hover:bg-campaign-gold/90 transition-colors" %>
        </div>

        <%= link_to events_path, class: "inline-flex items-center gap-2 text-navy-900 font-sans text-sm font-semibold hover:text-campaign-gold transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          Back to Events
        <% end %>
      </div>
    </div>
  </div>
</section>
