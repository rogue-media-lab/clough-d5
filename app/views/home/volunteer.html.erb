<% content_for :title, "Volunteer - Clough for SC5" %>

<!-- Hero Section -->
<div class="bg-navy-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Headline -->
      <div>
        <p class="text-campaign-gold font-semibold tracking-wider uppercase mb-4">Get Involved</p>
        <h1 class="font-display text-5xl md:text-6xl font-bold mb-6">
          Be part of<br/>something real.
        </h1>
        <p class="text-xl text-navy-200 mb-10 max-w-xl">
          Every door knocked, every call made, every yard sign planted — it all adds up.
        </p>
        
        <div class="flex gap-4">
          <a href="#join" class="bg-campaign-red hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Volunteer
          </a>
          <a href="#" class="border-2 border-white hover:bg-white hover:text-navy-900 text-white px-8 py-4 rounded-lg font-semibold transition-colors">
            Donate
          </a>
        </div>
      </div>
      
      <!-- Right: Progress Bar & Stats -->
      <div class="bg-navy-800 rounded-xl p-8">
        <div class="flex justify-between text-sm text-navy-300 mb-2">
          <span>1,812 volunteers</span>
          <span>2,000 goal</span>
        </div>
        <div class="h-4 bg-navy-900 rounded-full overflow-hidden mb-3">
          <div class="h-full bg-campaign-red rounded-full" style="width: 90.6%"></div>
        </div>
        <p class="text-navy-300 text-sm mb-6">188 more to reach our goal</p>
        
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-navy-900 rounded-lg p-4 text-center">
            <div class="text-3xl font-bold text-campaign-gold">1,812</div>
            <div class="text-navy-400 text-sm">Volunteers</div>
          </div>
          <div class="bg-navy-900 rounded-lg p-4 text-center">
            <div class="text-3xl font-bold text-campaign-gold">2,000</div>
            <div class="text-navy-400 text-sm">Goal</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- How You Can Help Section -->
<div class="bg-ivory-50 py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-campaign-red font-semibold tracking-wider uppercase mb-4">How You Can Help</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold text-navy-900 mb-4">
        Pick your role.
      </h2>
      <p class="text-navy-600 max-w-2xl mx-auto">
        Every role matters. Do as much or as little as you can — any help makes a difference.
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Canvassing -->
      <div class="bg-white rounded-xl p-8 shadow-sm border border-ivory-100 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-campaign-red/10 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-campaign-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="font-display text-xl font-bold text-navy-900 mb-2">Canvassing</h3>
        <p class="text-navy-600 text-sm mb-4">
          Walk neighborhoods and talk to voters face-to-face. The most effective way to reach people.
        </p>
        <span class="text-campaign-red text-sm font-medium">Learn more →</span>
      </div>
      
      <!-- Phone & Text Banking -->
      <div class="bg-white rounded-xl p-8 shadow-sm border border-ivory-100 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-campaign-red/10 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-campaign-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </div>
        <h3 class="font-display text-xl font-bold text-navy-900 mb-2">Phone & Text Banking</h3>
        <p class="text-navy-600 text-sm mb-4">
          Reach voters from your own home. Phone calls for older voters, texts for younger.
        </p>
        <span class="text-campaign-red text-sm font-medium">Learn more →</span>
      </div>
      
      <!-- Yard Signs -->
      <div class="bg-white rounded-xl p-8 shadow-sm border border-ivory-100 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-campaign-red/10 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-campaign-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
        </div>
        <h3 class="font-display text-xl font-bold text-navy-900 mb-2">Yard Signs</h3>
        <p class="text-navy-600 text-sm mb-4">
          Put a sign in your yard or help distribute them across the district.
        </p>
        <span class="text-campaign-red text-sm font-medium">Learn more →</span>
      </div>
      
      <!-- Social Media -->
      <div class="bg-white rounded-xl p-8 shadow-sm border border-ivory-100 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-campaign-red/10 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-campaign-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
          </svg>
        </div>
        <h3 class="font-display text-xl font-bold text-navy-900 mb-2">Social Media</h3>
        <p class="text-navy-600 text-sm mb-4">
          Share posts, write your own story about why you support Andrew.
        </p>
        <span class="text-campaign-red text-sm font-medium">Learn more →</span>
      </div>
      
      <!-- Host a House Party -->
      <div class="bg-white rounded-xl p-8 shadow-sm border border-ivory-100 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-campaign-red/10 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-campaign-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
        </div>
        <h3 class="font-display text-xl font-bold text-navy-900 mb-2">Host a House Party</h3>
        <p class="text-navy-600 text-sm mb-4">
          Invite neighbors over and bring Andrew to your living room. We provide the materials.
        </p>
        <span class="text-campaign-red text-sm font-medium">Learn more →</span>
      </div>
      
      <!-- Events & Rallies -->
      <div class="bg-white rounded-xl p-8 shadow-sm border border-ivory-100 hover:shadow-md transition-shadow">
        <div class="w-12 h-12 bg-campaign-red/10 rounded-lg flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-campaign-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="font-display text-xl font-bold text-navy-900 mb-2">Events & Rallies</h3>
        <p class="text-navy-600 text-sm mb-4">
          Help set up, greet attendees, and run the show at Coffee with Clough events.
        </p>
        <span class="text-campaign-red text-sm font-medium">Learn more →</span>
      </div>
    </div>
  </div>
</div>

<!-- Join the Campaign Form Section -->
<div id="join" class="bg-navy-900 py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <!-- Left: Message -->
      <div class="text-white">
        <p class="text-campaign-gold font-semibold tracking-wider uppercase mb-4">Get Involved</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-6">
          Ready to help?<br/>Let's talk.
        </h2>
        <p class="text-navy-200 text-lg mb-8">
          Fill in your details and check off whatever you're interested in. We'll be in touch soon.
        </p>
        <div class="flex gap-4">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-campaign-red" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-navy-200">No experience needed</span>
          </div>
        </div>
        <div class="flex gap-4 mt-2">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-campaign-red" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-navy-200">Flexible scheduling</span>
          </div>
        </div>
        <div class="flex gap-4 mt-2">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-campaign-red" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-navy-200">All skill levels welcome</span>
          </div>
        </div>
      </div>
      
      <!-- Right: Form -->
      <div class="bg-white rounded-xl p-8">
        <h3 class="font-display text-2xl font-bold text-navy-900 mb-6">Join the Campaign</h3>
        
        <%= form_with model: @volunteer_submission, url: volunteer_submissions_path, class: "space-y-4" do |form| %>
          <% if @volunteer_submission.errors.any? %>
            <div class="bg-red-50 text-red-600 p-3 rounded-lg text-sm">
              <%= @volunteer_submission.errors.full_messages.join(", ") %>
            </div>
          <% end %>
          
          <!-- Row 1: First Name | Last Name -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <%= form.label :name, "First Name", class: "block text-sm font-medium text-navy-700 mb-1" %>
              <%= form.text_field :name, class: "w-full px-4 py-3 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent", placeholder: "First name", required: true %>
            </div>
            <div>
              <%= form.label :last_name, "Last Name", class: "block text-sm font-medium text-navy-700 mb-1" %>
              <%= form.text_field :last_name, class: "w-full px-4 py-3 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent", placeholder: "Last name", required: true %>
            </div>
          </div>
          
          <!-- Row 2: Email (full width) -->
          <div>
            <%= form.label :email, "Email Address", class: "block text-sm font-medium text-navy-700 mb-1" %>
            <%= form.email_field :email, class: "w-full px-4 py-3 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent", placeholder: "your@email.com", required: true %>
          </div>
          
          <!-- Row 3: Phone | Zip Code -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <%= form.label :phone, "Phone (optional)", class: "block text-sm font-medium text-navy-700 mb-1" %>
              <%= form.telephone_field :phone, class: "w-full px-4 py-3 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent", placeholder: "(555) 123-4567" %>
            </div>
            <div>
              <%= form.label :area_code, "ZIP Code", class: "block text-sm font-medium text-navy-700 mb-1" %>
              <%= form.text_field :area_code, class: "w-full px-4 py-3 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent", placeholder: "29732" %>
            </div>
          </div>
          
          <!-- Row 4: Interests - 3 per column (2 columns) -->
          <% if @interests.any? %>
            <div>
              <label class="block text-sm font-medium text-navy-700 mb-2">I want to help with:</label>
              <div class="grid grid-cols-2 gap-2">
                <%= collection_check_boxes(:volunteer_submission, :interest_ids, @interests, :id, :name) do |b| %>
                  <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-ivory-50 cursor-pointer">
                    <%= b.check_box(class: "rounded text-campaign-red focus:ring-campaign-red") %>
                    <span class="text-navy-700 text-sm"><%= b.label %></span>
                  </label>
                <% end %>
              </div>
            </div>
          <% end %>
          
          <!-- Message at bottom (per user request) -->
          <div>
            <%= form.label :message, "Message (optional)", class: "block text-sm font-medium text-navy-700 mb-1" %>
            <%= form.text_area :message, rows: 2, class: "w-full px-4 py-3 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent", placeholder: "Any questions or comments?" %>
          </div>
          
          <%= form.submit "Count Me In", class: "w-full bg-campaign-red hover:bg-red-700 text-white py-4 rounded-lg font-semibold transition-colors cursor-pointer text-lg" %>
          
          <p class="text-xs text-navy-500 text-center">
            Your information is private and will never be sold.
          </p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<footer class="bg-navy-950 text-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <h3 class="font-display text-2xl font-bold mb-4">Clough for SC5</h3>
        <p class="text-ivory-300 mb-6 max-w-md">
          Conservative leadership for South Carolina District 5. Join us in
          making our community stronger, freer, and more prosperous.
        </p>
        <div class="flex gap-4">
          <a href="#" class="text-ivory-300 hover:text-white transition-colors">
            <span class="sr-only">Facebook</span>
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="text-ivory-300 hover:text-white transition-colors">
            <span class="sr-only">Twitter</span>
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="text-ivory-300 hover:text-white transition-colors">
            <span class="sr-only">Instagram</span>
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li><%= link_to "Home", root_path, class: "text-ivory-300 hover:text-white transition-colors" %></li>
          <li><%= link_to "Issues", "#issues", class: "text-ivory-300 hover:text-white transition-colors" %></li>
          <li><%= link_to "News", news_path, class: "text-ivory-300 hover:text-white transition-colors" %></li>
          <li><%= link_to "Events", events_path, class: "text-ivory-300 hover:text-white transition-colors" %></li>
          <li><%= link_to "About", about_path, class: "text-ivory-300 hover:text-white transition-colors" %></li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Get Involved</h4>
        <ul class="space-y-2">
          <li><%= link_to "Volunteer", volunteer_path, class: "text-ivory-300 hover:text-white transition-colors" %></li>
          <li><a href="#" class="text-ivory-300 hover:text-white transition-colors">Request Yard Sign</a></li>
          <li><a href="#" class="text-ivory-300 hover:text-white transition-colors">Donate</a></li>
          <li><a href="#" class="text-ivory-300 hover:text-white transition-colors">Contact Us</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-navy-800 text-center text-ivory-400 text-sm">
      <p>© 2026 Clough for SC5. Paid for by Clough for SC5.</p>
    </div>
  </div>
</footer>