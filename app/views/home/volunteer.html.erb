
<%# Hero Section %>
<section class="bg-navy-900 w-full">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-10 lg:gap-[120px] px-6 py-12 lg:px-20 lg:py-20">
    <div class="flex-1 flex flex-col gap-5">
      <div class="flex items-center gap-3">
        <div class="bg-campaign-gold h-0.5 w-10"></div>
        <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.1em] uppercase">Get Involved</span>
      </div>
      <h1 class="text-white font-display text-4xl sm:text-5xl lg:text-[56px] font-bold leading-[1.1]">
        Be part of<br />something real.
      </h1>
      <p class="text-white/65 font-sans text-base leading-relaxed max-w-lg">
        Every door knocked, every call made, every yard sign planted — it adds up. Andrew can't win this without neighbors who believe District 5 deserves better. That's you.
      </p>
    </div>
    <div class="w-full lg:w-[440px] bg-white/[0.07] rounded-xl p-6 sm:p-10 flex flex-col gap-6">
      <div class="flex justify-between items-end">
        <div class="flex flex-col gap-1">
          <span class="text-white font-display text-4xl lg:text-[48px] font-bold leading-none">312</span>
          <span class="text-white/50 font-sans text-sm">volunteers and counting</span>
        </div>
        <div class="flex flex-col gap-1 items-end">
          <span class="text-campaign-gold font-sans text-sm font-semibold">Goal: 500</span>
          <span class="text-white/40 font-sans text-xs">before primary</span>
        </div>
      </div>
      <div class="flex flex-col gap-2">
        <div class="bg-white/12 rounded-full h-2 w-full overflow-hidden">
          <div class="bg-campaign-gold rounded-full h-full w-[62%]"></div>
        </div>
        <span class="text-white/40 font-sans text-xs">188 more to reach our goal</span>
      </div>
      <div class="border-t border-white/10 pt-6 flex gap-4">
        <div class="flex-1 flex flex-col gap-1">
          <span class="text-white font-display text-2xl font-bold">6</span>
          <span class="text-white/45 font-sans text-xs">counties represented</span>
        </div>
        <div class="flex-1 flex flex-col gap-1">
          <span class="text-white font-display text-2xl font-bold">1,400+</span>
          <span class="text-white/45 font-sans text-xs">doors knocked</span>
        </div>
      </div>
    </div>
  </div>
</section>

<%# Role Cards Section %>
<section class="bg-ivory-50 w-full">
  <div class="max-w-7xl mx-auto px-6 py-16 lg:px-20 lg:py-20 flex flex-col gap-12">
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-3">
        <div class="bg-campaign-gold h-0.5 w-10"></div>
        <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.1em] uppercase">How You Can Help</span>
      </div>
      <h2 class="text-navy-900 font-display text-3xl lg:text-[36px] font-bold">Pick your role.</h2>
      <p class="text-gray-500 font-sans text-base leading-relaxed max-w-lg">Every role matters. Do as much or as little as you can — an hour a week moves the needle. Sign up below and we'll match you to opportunities in your area.</p>
    </div>

    <div class="flex flex-col gap-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <%# Row 1 - Gold top border %>
        <div class="bg-white rounded-lg border-t-4 border-campaign-gold p-6 lg:p-8 flex flex-col gap-4">
          <h3 class="text-navy-900 font-display text-xl font-bold">Canvassing</h3>
          <p class="text-gray-500 font-sans text-sm leading-[1.65] flex-1">Walk neighborhoods and talk to voters face-to-face. The most effective thing a campaign can do. We provide the list, the script, and the training.</p>
          <div class="flex items-center gap-2 mt-auto pt-1">
            <div class="bg-campaign-gold h-0.5 w-4"></div>
            <span class="text-campaign-gold font-sans text-[11px] font-semibold tracking-[0.1em] uppercase">Most impactful</span>
          </div>
        </div>
        <div class="bg-white rounded-lg border-t-4 border-campaign-gold p-6 lg:p-8 flex flex-col gap-4">
          <h3 class="text-navy-900 font-display text-xl font-bold">Phone & Text Banking</h3>
          <p class="text-gray-500 font-sans text-sm leading-[1.65] flex-1">Reach voters from your own home. Phone calls for older voters, text banking for everyone else. A few hours on a weekend goes a long way.</p>
          <div class="flex items-center gap-2 mt-auto pt-1">
            <div class="bg-campaign-gold h-0.5 w-4"></div>
            <span class="text-campaign-gold font-sans text-[11px] font-semibold tracking-[0.1em] uppercase">Do it from home</span>
          </div>
        </div>
        <div class="bg-white rounded-lg border-t-4 border-campaign-gold p-6 lg:p-8 flex flex-col gap-4">
          <h3 class="text-navy-900 font-display text-xl font-bold">Yard Signs</h3>
          <p class="text-gray-500 font-sans text-sm leading-[1.65] flex-1">Put a sign in your yard or help distribute them across the district. Visibility builds name recognition — especially in the final weeks before the primary.</p>
          <div class="flex items-center gap-2 mt-auto pt-1">
            <div class="bg-campaign-gold h-0.5 w-4"></div>
            <span class="text-campaign-gold font-sans text-[11px] font-semibold tracking-[0.1em] uppercase">Lowest time commitment</span>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <%# Row 2 - Navy top border %>
        <div class="bg-white rounded-lg border-t-4 border-navy-900 p-6 lg:p-8 flex flex-col gap-4">
          <h3 class="text-navy-900 font-display text-xl font-bold">Social Media</h3>
          <p class="text-gray-500 font-sans text-sm leading-[1.65] flex-1">Share posts, write your own story about why you support Andrew, and help expand the campaign's reach beyond what advertising can do.</p>
          <div class="flex items-center gap-2 mt-auto pt-1">
            <div class="bg-gray-500 h-0.5 w-4"></div>
            <span class="text-gray-500 font-sans text-[11px] font-semibold tracking-[0.1em] uppercase">Anytime, anywhere</span>
          </div>
        </div>
        <div class="bg-white rounded-lg border-t-4 border-navy-900 p-6 lg:p-8 flex flex-col gap-4">
          <h3 class="text-navy-900 font-display text-xl font-bold">Host a House Party</h3>
          <p class="text-gray-500 font-sans text-sm leading-[1.65] flex-1">Invite neighbors over and bring Andrew to your living room. House parties are how grassroots campaigns build real, lasting support in a community.</p>
          <div class="flex items-center gap-2 mt-auto pt-1">
            <div class="bg-gray-500 h-0.5 w-4"></div>
            <span class="text-gray-500 font-sans text-[11px] font-semibold tracking-[0.1em] uppercase">High impact</span>
          </div>
        </div>
        <div class="bg-white rounded-lg border-t-4 border-navy-900 p-6 lg:p-8 flex flex-col gap-4">
          <h3 class="text-navy-900 font-display text-xl font-bold">Events & Rallies</h3>
          <p class="text-gray-500 font-sans text-sm leading-[1.65] flex-1">Help set up, greet attendees, and run the show at Coffee with Clough events and town halls. Energy at events is contagious — we need good people in the room.</p>
          <div class="flex items-center gap-2 mt-auto pt-1">
            <div class="bg-gray-500 h-0.5 w-4"></div>
            <span class="text-gray-500 font-sans text-[11px] font-semibold tracking-[0.1em] uppercase">In-person</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<%# Sign Up Form Section %>
<section class="bg-navy-900 w-full">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-start gap-10 lg:gap-[120px] px-6 py-16 lg:px-20 lg:py-20">
    <div class="flex-1 flex flex-col gap-7">
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-3">
          <div class="bg-campaign-gold h-0.5 w-10"></div>
          <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.1em] uppercase">Sign Up</span>
        </div>
        <h2 class="text-white font-display text-3xl sm:text-4xl lg:text-[40px] font-bold leading-[1.1]">Ready to help?<br />Let's talk.</h2>
      </div>
      <p class="text-white/60 font-sans text-base leading-relaxed">
        Fill in your details and check off whatever you're interested in. A member of the campaign team will reach out within 48 hours to get you plugged in.
      </p>
    </div>
    <div class="w-full lg:w-[560px] bg-white rounded-xl p-6 sm:p-12 flex flex-col gap-5">
      <%= form_with model: @volunteer_submission, url: volunteer_submissions_path, method: :post do |form| %>
        <h3 class="text-navy-900 font-display text-2xl font-bold">Join the Campaign</h3>

        <div class="flex flex-col sm:flex-row gap-4 mt-5">
          <div class="flex-1 flex flex-col gap-1.5">
            <%= form.label :name, "First Name", class: "text-gray-500 font-sans text-[11px] font-semibold uppercase" %>
            <%= form.text_field :name, class: "bg-ivory-50 border border-gray-200 rounded h-11 px-3 w-full" %>
          </div>
          <div class="flex-1 flex flex-col gap-1.5">
            <%= form.label :last_name, "Last Name", class: "text-gray-500 font-sans text-[11px] font-semibold uppercase" %>
            <%= form.text_field :last_name, class: "bg-ivory-50 border border-gray-200 rounded h-11 px-3 w-full" %>
          </div>
        </div>

        <div class="flex flex-col gap-1.5 mt-5">
          <%= form.label :email, "Email Address", class: "text-gray-500 font-sans text-[11px] font-semibold uppercase" %>
          <%= form.email_field :email, class: "bg-ivory-50 border border-gray-200 rounded h-11 px-3 w-full" %>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 mt-5">
          <div class="flex-1 flex flex-col gap-1.5">
            <%= form.label :phone, "Phone (optional)", class: "text-gray-500 font-sans text-[11px] font-semibold uppercase" %>
            <%= form.telephone_field :phone, class: "bg-ivory-50 border border-gray-200 rounded h-11 px-3 w-full" %>
          </div>
          <div class="w-full sm:w-[140px] flex flex-col gap-1.5">
            <%= form.label :area_code, "ZIP Code", class: "text-gray-500 font-sans text-[11px] font-semibold uppercase" %>
            <%= form.text_field :area_code, class: "bg-ivory-50 border border-gray-200 rounded h-11 px-3 w-full" %>
          </div>
        </div>

        <div class="flex flex-col gap-3 pt-6">
          <span class="text-gray-500 font-sans text-[11px] font-semibold uppercase">I want to help with…</span>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <% @interests.each do |interest| %>
              <div class="interest-checkbox flex items-center gap-3 bg-ivory-50 border border-gray-200 rounded px-4 py-3 cursor-pointer hover:border-campaign-gold transition-colors">
                <%= check_box_tag "volunteer_submission[interest_ids][]", interest.id, @volunteer_submission.interest_ids.include?(interest.id), { id: "interest_#{interest.id}", class: "sr-only peer" } %>
                <label for="interest_<%= interest.id %>" class="flex items-center gap-3 w-full cursor-pointer">
                  <div class="custom-checkbox h-[18px] w-[18px] border-2 border-gray-200 rounded bg-white flex items-center justify-center flex-shrink-0 peer-checked:bg-campaign-gold peer-checked:border-campaign-gold">
                    <span class="hidden text-white text-xs">✓</span>
                  </div>
                  <span class="text-gray-700 font-sans text-sm"><%= interest.name %></span>
                </label>
              </div>
            <% end %>
          </div>
        </div>

        <div class="mt-6">
          <%= form.submit "Count Me In", class: "bg-campaign-gold hover:bg-campaign-gold-dark text-white font-sans text-sm font-bold tracking-wider uppercase border-0 rounded px-6 py-[18px] w-full cursor-pointer transition-colors" %>
        </div>
        <p class="text-gray-400 font-sans text-xs text-center mt-5">Your information is private and will never be sold. View our <%= link_to "Privacy Policy", privacy_path, class: "text-campaign-gold hover:underline" %>.</p>
      <% end %>
    </div>
  </div>
</section>

<style>
.interest-checkbox input[type="checkbox"]:checked + label .custom-checkbox {
  background-color: #C8902A;
  border-color: #C8902A;
}
.interest-checkbox input[type="checkbox"]:checked + label .custom-checkbox span {
  display: inline;
}
</style>
