<% content_for :title, "Volunteer - Clough for SC5" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
  <div class="text-center mb-12">
    <p class="text-campaign-red font-semibold tracking-wider uppercase mb-4">Get Involved</p>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-navy-900 mb-6">
      Volunteer With Us
    </h1>
    <p class="text-xl text-navy-600 max-w-2xl mx-auto">
      Join the team and help bring conservative leadership to District 5.
    </p>
  </div>

  <div class="grid md:grid-cols-2 gap-12 items-start">
    <div class="bg-ivory-50 rounded-xl p-8">
      <h2 class="font-display text-2xl font-bold text-navy-900 mb-6">Ways to Volunteer</h2>
      <ul class="space-y-6">
        <li class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-campaign-red text-white rounded-lg flex items-center justify-center text-xl">📞</div>
          <div>
            <h3 class="font-semibold text-navy-900">Phone Banking</h3>
            <p class="text-navy-600 text-sm">Call voters in District 5 to spread the message.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-campaign-red text-white rounded-lg flex items-center justify-center text-xl">🚗</div>
          <div>
            <h3 class="font-semibold text-navy-900">Canvassing</h3>
            <p class="text-navy-600 text-sm">Knock on doors and talk to your neighbors.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-campaign-red text-white rounded-lg flex items-center justify-center text-xl">📋</div>
          <div>
            <h3 class="font-semibold text-navy-900">Event Support</h3>
            <p class="text-navy-600 text-sm">Help at rallies, town halls, and meet-and-greets.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-campaign-red text-white rounded-lg flex items-center justify-center text-xl">💻</div>
          <div>
            <h3 class="font-semibold text-navy-900">Digital Outreach</h3>
            <p class="text-navy-600 text-sm">Share content on social media and online.</p>
          </div>
        </li>
      </ul>
    </div>

    <div class="bg-white rounded-xl shadow-lg p-8 border border-ivory-100">
      <h2 class="font-display text-2xl font-bold text-navy-900 mb-6">Sign Up to Volunteer</h2>
      <form class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-navy-700 mb-1">Full Name</label>
          <input type="text" class="w-full px-4 py-2 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent" placeholder="Your name">
        </div>
        <div>
          <label class="block text-sm font-medium text-navy-700 mb-1">Email</label>
          <input type="email" class="w-full px-4 py-2 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent" placeholder="your@email.com">
        </div>
        <div>
          <label class="block text-sm font-medium text-navy-700 mb-1">Phone</label>
          <input type="tel" class="w-full px-4 py-2 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent" placeholder="(555) 123-4567">
        </div>
        <div>
          <label class="block text-sm font-medium text-navy-700 mb-1">Zip Code</label>
          <input type="text" class="w-full px-4 py-2 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent" placeholder="29732">
        </div>
        <div>
          <label class="block text-sm font-medium text-navy-700 mb-2">I'm interested in:</label>
          <div class="space-y-2">
            <label class="flex items-center gap-2">
              <input type="checkbox" class="rounded text-campaign-red">
              <span class="text-navy-700">Phone Banking</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" class="rounded text-campaign-red">
              <span class="text-navy-700">Canvassing</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" class="rounded text-campaign-red">
              <span class="text-navy-700">Event Support</span>
            </label>
            <label class="flex items-center gap-2">
              <input type="checkbox" class="rounded text-campaign-red">
              <span class="text-navy-700">Digital Outreach</span>
            </label>
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-navy-700 mb-1">Message (optional)</label>
          <textarea rows="3" class="w-full px-4 py-2 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent" placeholder="Any questions or comments?"></textarea>
        </div>
        <button type="submit" class="w-full bg-campaign-red hover:bg-campaign-red-dark text-white py-3 rounded-lg font-semibold transition-colors">
          Sign Up to Volunteer
        </button>
      </form>
    </div>
  </div>
</div>