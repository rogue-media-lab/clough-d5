<% content_for :title, "Volunteer - Clough for SC5" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
  <div class="text-center mb-12">
    <p class="text-campaign-red font-semibold tracking-wider uppercase mb-4">Get Involved</p>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-navy-900 mb-6">
      Volunteer With Us
    </h1>
    <p class="text-xl text-navy-600 max-w-2xl mx-auto">
      Join the team and help bring conservative leadership to District 5.
    </p>
  </div>

  <div class="grid md:grid-cols-2 gap-12 items-start">
    <div class="bg-ivory-50 rounded-xl p-8">
      <h2 class="font-display text-2xl font-bold text-navy-900 mb-6">Ways to Volunteer</h2>
      <ul class="space-y-6">
        <li class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-campaign-red text-white rounded-lg flex items-center justify-center text-xl">📞</div>
          <div>
            <h3 class="font-semibold text-navy-900">Phone Banking</h3>
            <p class="text-navy-600 text-sm">Call voters in District 5 to spread the message.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-campaign-red text-white rounded-lg flex items-center justify-center text-xl">🚗</div>
          <div>
            <h3 class="font-semibold text-navy-900">Canvassing</h3>
            <p class="text-navy-600 text-sm">Knock on doors and talk to your neighbors.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-campaign-red text-white rounded-lg flex items-center justify-center text-xl">📋</div>
          <div>
            <h3 class="font-semibold text-navy-900">Event Support</h3>
            <p class="text-navy-600 text-sm">Help at rallies, town halls, and meet-and-greets.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-campaign-red text-white rounded-lg flex items-center justify-center text-xl">💻</div>
          <div>
            <h3 class="font-semibold text-navy-900">Digital Outreach</h3>
            <p class="text-navy-600 text-sm">Share content on social media and online.</p>
          </div>
        </li>
      </ul>
    </div>

    <div class="bg-white rounded-xl shadow-lg p-8 border border-ivory-100">
      <h2 class="font-display text-2xl font-bold text-navy-900 mb-6">Sign Up to Volunteer</h2>
      
      <%= form_with model: @volunteer_submission, url: volunteer_submissions_path, class: "space-y-4" do |form| %>
        <% if @volunteer_submission.errors.any? %>
          <div class="bg-red-50 text-red-600 p-3 rounded-lg text-sm">
            <%= @volunteer_submission.errors.full_messages.join(", ") %>
          </div>
        <% end %>
        
        <div>
          <%= form.label :name, "Full Name", class: "block text-sm font-medium text-navy-700 mb-1" %>
          <%= form.text_field :name, class: "w-full px-4 py-2 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent", placeholder: "Your name", required: true %>
        </div>
        <div>
          <%= form.label :email, "Email", class: "block text-sm font-medium text-navy-700 mb-1" %>
          <%= form.email_field :email, class: "w-full px-4 py-2 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent", placeholder: "your@email.com", required: true %>
        </div>
        <div>
          <%= form.label :phone, "Phone", class: "block text-sm font-medium text-navy-700 mb-1" %>
          <%= form.telephone_field :phone, class: "w-full px-4 py-2 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent", placeholder: "(555) 123-4567" %>
        </div>
        <div>
          <%= form.label :area_code, "Zip Code", class: "block text-sm font-medium text-navy-700 mb-1" %>
          <%= form.text_field :area_code, class: "w-full px-4 py-2 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent", placeholder: "29732" %>
        </div>
        
        <% if @interests.any? %>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-2">I'm interested in:</label>
            <div class="space-y-2">
              <%= collection_check_boxes(:volunteer_submission, :interest_ids, @interests, :id, :name) do |b| %>
                <label class="flex items-center gap-2">
                  <%= b.check_box(class: "rounded text-campaign-red") %>
                  <span class="text-navy-700"><%= b.label %></span>
                </label>
              <% end %>
            </div>
          </div>
        <% end %>
        
        <div>
          <%= form.label :message, "Message (optional)", class: "block text-sm font-medium text-navy-700 mb-1" %>
          <%= form.text_area :message, rows: 3, class: "w-full px-4 py-2 border border-ivory-300 rounded-lg focus:ring-2 focus:ring-campaign-red focus:border-transparent", placeholder: "Any questions or comments?" %>
        </div>
        <%= form.submit "Sign Up to Volunteer", class: "w-full bg-campaign-red hover:bg-red-700 text-white py-3 rounded-lg font-semibold transition-colors cursor-pointer" %>
      <% end %>
    </div>
  </div>
</div>