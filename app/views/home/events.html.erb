        </div>
      </div>

      <div>
        <h4 class="font-semibold mb-4">Quick Links</h4>
        <ul class="space-y-2">
          <li><%= link_to "Home", root_path, class: "text-ivory-300 hover:text-white transition-colors" %></li>
