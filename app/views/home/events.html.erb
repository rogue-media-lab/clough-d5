<% content_for :title, "Events - Clough for SC5" %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
  <div class="text-center mb-12">
    <p class="text-campaign-red font-semibold tracking-wider uppercase mb-4">Events</p>
    <h1 class="font-display text-5xl md:text-6xl font-bold text-navy-900 mb-6">
      Upcoming Events
    </h1>
    <p class="text-xl text-navy-600 max-w-2xl mx-auto">
      Join Andrew at events across District 5. Your voice matters.
    </p>
  </div>

  <%# Events List %>
  <div class="space-y-4 max-w-4xl mx-auto mb-16">
    <div class="flex flex-col md:flex-row gap-4 p-6 border border-ivory-200 rounded-xl hover:shadow-md transition-shadow bg-white">
      <div class="flex-shrink-0 bg-campaign-red text-white rounded-lg p-4 text-center w-20 h-20 flex flex-col justify-center">
        <div class="text-2xl font-bold">15</div>
        <div class="text-xs uppercase">May</div>
      </div>
      <div class="flex-1">
        <h3 class="font-display text-xl font-bold text-navy-900 mb-1">Campaign Kickoff Rally</h3>
        <p class="text-navy-600 mb-2">Join us for the official campaign kickoff! Food, drinks, and conversation.</p>
        <div class="flex flex-wrap gap-4 text-sm text-navy-500">
          <span class="flex items-center gap-1">📍 Rock Hill Convention Center</span>
          <span class="flex items-center gap-1">🕕 6:00 PM</span>
        </div>
      </div>
      <div class="flex-shrink-0 flex items-center">
        <button class="bg-campaign-red hover:bg-campaign-red-dark text-white px-6 py-2 rounded-lg font-semibold transition-colors">
          RSVP
        </button>
      </div>
    </div>

    <div class="flex flex-col md:flex-row gap-4 p-6 border border-ivory-200 rounded-xl hover:shadow-md transition-shadow bg-white">
      <div class="flex-shrink-0 bg-navy-700 text-white rounded-lg p-4 text-center w-20 h-20 flex flex-col justify-center">
        <div class="text-2xl font-bold">22</div>
        <div class="text-xs uppercase">May</div>
      </div>
      <div class="flex-1">
        <h3 class="font-display text-xl font-bold text-navy-900 mb-1">Town Hall Meeting</h3>
        <p class="text-navy-600 mb-2">An open town hall where you can ask Andrew anything about his platform.</p>
        <div class="flex flex-wrap gap-4 text-sm text-navy-500">
          <span class="flex items-center gap-1">📍 York County Library</span>
          <span class="flex items-center gap-1">🕖 7:00 PM</span>
        </div>
      </div>
      <div class="flex-shrink-0 flex items-center">
        <button class="bg-navy-700 hover:bg-navy-800 text-white px-6 py-2 rounded-lg font-semibold transition-colors">
          RSVP
        </button>
      </div>
    </div>

    <div class="flex flex-col md:flex-row gap-4 p-6 border border-ivory-200 rounded-xl hover:shadow-md transition-shadow bg-white">
      <div class="flex-shrink-0 bg-navy-700 text-white rounded-lg p-4 text-center w-20 h-20 flex flex-col justify-center">
        <div class="text-2xl font-bold">05</div>
        <div class="text-xs uppercase">Jun</div>
      </div>
      <div class="flex-1">
        <h3 class="font-display text-xl font-bold text-navy-900 mb-1">Community Picnic</h3>
        <p class="text-navy-600 mb-2">Bring the family for a casual afternoon of food and fellowship.</p>
        <div class="flex flex-wrap gap-4 text-sm text-navy-500">
          <span class="flex items-center gap-1">📍 Chester State Park</span>
          <span class="flex items-center gap-1">🕛 12:00 PM</span>
        </div>
      </div>
      <div class="flex-shrink-0 flex items-center">
        <button class="bg-navy-700 hover:bg-navy-800 text-white px-6 py-2 rounded-lg font-semibold transition-colors">
          RSVP
        </button>
      </div>
    </div>

    <div class="flex flex-col md:flex-row gap-4 p-6 border border-ivory-200 rounded-xl hover:shadow-md transition-shadow bg-white">
      <div class="flex-shrink-0 bg-navy-700 text-white rounded-lg p-4 text-center w-20 h-20 flex flex-col justify-center">
        <div class="text-2xl font-bold">12</div>
        <div class="text-xs uppercase">Jun</div>
      </div>
      <div class="flex-1">
        <h3 class="font-display text-xl font-bold text-navy-900 mb-1">Coffee with Clough</h3>
        <p class="text-navy-600 mb-2">Casual coffee shop meetup. Come say hi and learn more about the campaign.</p>
        <div class="flex flex-wrap gap-4 text-sm text-navy-500">
          <span class="flex items-center gap-1">📍 Brew & Bloom, Rock Hill</span>
          <span class="flex items-center gap-1">🕙 10:00 AM</span>
        </div>
      </div>
      <div class="flex-shrink-0 flex items-center">
        <button class="bg-navy-700 hover:bg-navy-800 text-white px-6 py-2 rounded-lg font-semibold transition-colors">
          RSVP
        </button>
      </div>
    </div>
  </div>

  <%# Past Events Section %>
  <section>
    <h2 class="font-display text-2xl font-bold text-navy-900 mb-6 text-center">Past Events</h2>
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-ivory-50 rounded-xl p-6">
        <p class="text-sm text-navy-500 mb-2">April 2026</p>
        <h3 class="font-semibold text-navy-900 mb-2">Campaign Announcement</h3>
        <p class="text-sm text-navy-600">Andrew officially announced his candidacy for SC District 5.</p>
      </div>
    </div>
  </section>

  <%# Host an Event CTA %>
  <section class="mt-16 bg-campaign-red text-white rounded-2xl p-8 md:p-12 text-center">
    <h2 class="font-display text-3xl font-bold mb-4">Want to Host an Event?</h2>
    <p class="text-ivory-100 mb-6 max-w-2xl mx-auto">
      Interested in hosting a meet-and-greet or house party? We'd love to come speak to your group.
    </p>
    <%= link_to "Contact Us", volunteer_path,
          class: "inline-block bg-white text-campaign-red hover:bg-ivory-100 px-8 py-3 rounded-lg font-semibold transition-colors" %>
  </section>
</div>