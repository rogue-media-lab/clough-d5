<% content_for :title, "Events - Clough for SC5" %>

<%# Hero Section with Background Image %>
<div class="relative bg-navy-900 text-white overflow-hidden">
  <div class="absolute inset-0">
    <%# Placeholder for a real image %>
    <div class="absolute inset-0 bg-black opacity-40"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-32 text-center">
    <p class="text-campaign-gold font-semibold tracking-wider uppercase mb-4">Events</p>
    <h1 class="font-display text-5xl md:text-6xl font-bold mb-4">
      Join Us on the Trail
    </h1>
    <p class="text-xl text-ivory-100 max-w-2xl mx-auto">
      Meet Andrew, hear his vision for District 5, and get involved in the campaign.
    </p>
  </div>
</div>

<%# Featured Event Section %>
<section class="-mt-16 md:-mt-24 z-10 relative">
  <div class="max-w-4xl mx-auto px-4">
    <div class="bg-white rounded-2xl shadow-xl border border-ivory-100 grid md:grid-cols-3 overflow-hidden">
      <div class="md:col-span-1 bg-navy-100 flex items-center justify-center p-6">
        <%# Placeholder for an actual image %>
        <div class="w-full h-48 bg-navy-200 rounded-lg flex items-center justify-center">
          <span class="text-7xl">🎉</span>
        </div>
      </div>
      <div class="md:col-span-2 p-8">
        <p class="text-campaign-red font-semibold tracking-wider uppercase mb-2">Featured Event</p>
        <h2 class="font-display text-3xl font-bold text-navy-900 mb-2">Campaign Kickoff Rally</h2>
        <p class="text-navy-600 mb-4">
          This is the big one! Join us for the official launch of the campaign with food, music, and 
          a special announcement from Andrew.
        </p>
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm text-navy-700 mb-6">
          <span class="flex items-center gap-2 font-medium">📍 Rock Hill Convention Center</span>
          <span class="flex items-center gap-2 font-medium">🗓️ Saturday, May 15th, 2026</span>
          <span class="flex items-center gap-2 font-medium">🕕 6:00 PM - 8:00 PM</span>
        </div>
        <a href="#" class="inline-block bg-campaign-red hover:bg-red-700 text-white px-8 py-3 rounded-lg font-semibold transition-colors">
          Get Tickets
        </a>
      </div>
    </div>
  </div>
</section>

<%# Calendar Section %>
<section class="py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-display text-4xl font-bold text-navy-900">May 2026</h2>
    </div>
    
    <%# Calendar Grid - This is a simplified representation %>
    <div class="grid grid-cols-7 gap-px bg-ivory-200 border border-ivory-200 rounded-lg overflow-hidden">
      <%# Calendar Header %>
      <% ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"].each do |day| %>
        <div class="bg-ivory-50 p-2 text-center text-sm font-semibold text-navy-600"><%= day %></div>
      <% end %>
      
      <%# Calendar Body - Placeholder structure %>
      <% (1..31).to_a.each do |day| %>
        <div class="bg-white p-2 min-h-[120px] aspect-square relative">
          <div class="text-sm text-navy-800 font-medium"><%= day %></div>
          <%# Example of an event card %>
          <% if day == 22 %>
            <div class="bg-campaign-red text-white p-2 rounded-md text-xs mt-1 cursor-pointer hover:bg-red-700">
              <p class="font-bold truncate">Town Hall</p>
              <p class="truncate">York County Library</p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
    
    <div class="text-center mt-12">
      <div class="inline-flex items-center gap-4">
        <button class="text-navy-500 hover:text-navy-800">← April</button>
        <button class="text-navy-500 hover:text-navy-800">June →</button>
      </div>
    </div>
  </div>
</section>


<%# Host an Event CTA %>
<section class="bg-ivory-50 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-navy-900 text-white rounded-2xl p-8 md:p-12 text-center">
      <h2 class="font-display text-3xl font-bold mb-4">Host Your Own Event</h2>
      <p class="text-ivory-200 mb-6 max-w-2xl mx-auto">
        Interested in hosting a meet-and-greet in your neighborhood or a house party for friends?
        We'd love to bring Andrew to you. Let us know!
      </p>
      <%= link_to "Contact Us to Host", volunteer_path,
            class: "inline-block bg-campaign-red hover:bg-red-700 text-white px-8 py-3 rounded-lg font-semibold transition-colors" %>
    </div>
  </div>
</section>

<footer class="bg-navy-950 text-white py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <h3 class="font-display text-2xl font-bold mb-4">Clough for SC5</h3>
        <p class="text-ivory-300 mb-6 max-w-md">
          Conservative leadership for South Carolina District 5. Join us in
          making our community stronger, freer, and more prosperous.
        </p>
        <div class="flex gap-4">
          <a href="#" class="text-ivory-300 hover:text-white transition-colors">
