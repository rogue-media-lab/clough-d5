<div style="background-color: #FFFFFF; width: 100%; box-sizing: border-box;">
  <div style="max-width: 1440px; margin-inline: auto; display: flex; flex-direction: column; gap: 40px; padding: 80px;">
    <div style="display: flex; justify-content: space-between; align-items: flex-end;">
      <div style="display: flex; flex-direction: column; gap: 8px;">
