        <div style="display: flex; align-items: flex-start; gap: 20px;">
          <div style="background-color: #0F2044; border-radius: 6px; padding: 12px 16px; display: flex; flex-direction: column; align-items: center; flex-shrink: 0;">
            <div style="color: #C8902A; font-family: 'Inter', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;">APR</div>
