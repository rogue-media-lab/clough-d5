<% content_for :title, "Events - Clough for SC5" %>

<%# Hero Section %>
<div class="bg-navy-900 text-white py-16 md:py-24 bg-cover bg-center" style="background-image: url(<%= image_path 'event-hero-bg.jpg' %>);">
  <div class="bg-navy-900 bg-opacity-80 py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-5xl md:text-6xl font-bold mb-4">
        Upcoming Events
      </h1>
      <p class="text-xl text-navy-200 max-w-2xl mx-auto">
        Join Andrew at events across District 5. Your voice matters.
      </p>
    </div>
  </div>
</div>

<%# Featured Event %>
<% if @featured_event %>
<section class="py-16 md:py-24 bg-ivory-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1">
        <div class="aspect-w-16 aspect-h-9 rounded-xl overflow-hidden shadow-lg">
          <%= image_tag 'featured-event.jpg', class: "w-full h-full object-cover" %>
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <p class="text-campaign-red font-semibold tracking-wider uppercase mb-4">Featured Event</p>
        <h2 class="font-display text-4xl font-bold text-navy-900 mb-4">
          <%= @featured_event.title %>
        </h2>
        <p class="text-navy-600 text-lg mb-6">
          <%= @featured_event.description %>
        </p>
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-navy-700 mb-8">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-campaign-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <span><%= @featured_event.date.strftime("%A, %B %d, %Y") %></span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-campaign-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span><%= @featured_event.location %></span>
          </div>
        </div>
        <%= link_to "View Details & RSVP", "#", class: "bg-campaign-red hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors" %>
      </div>
    </div>
  </div>
</section>
<% end %>

<%# Calendar Section %>
<section class="py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-display text-4xl font-bold text-navy-900">Event Calendar</h2>
    </div>

    <% @upcoming_events.each do |month, events| %>
      <div class="mb-12">
        <h3 class="font-display text-2xl font-bold text-navy-900 mb-6"><%= month.strftime("%B %Y") %></h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <% events.each do |event| %>
            <div class="bg-white border border-ivory-200 rounded-xl shadow-sm hover:shadow-lg transition-shadow overflow-hidden flex flex-col">
              <div class="p-6 flex-grow">
                <div class="flex items-start justify-between mb-4">
                    <div class="text-center bg-ivory-100 rounded-lg px-3 py-1">
                      <div class="font-bold text-campaign-red text-2xl"><%= event.date.strftime("%d") %></div>
                      <div class="text-xs uppercase text-navy-600"><%= event.date.strftime("%b") %></div>
                    </div>
                    <div class="text-right">
                      <p class="font-semibold text-navy-600"><%= event.date.strftime("%l:%M %p") %></p>
                    </div>
                </div>
                <h4 class="font-display text-xl font-bold text-navy-900 mb-2"><%= event.title %></h4>
                <p class="text-sm text-navy-600 mb-4"><%= event.description %></p>
              </div>
              <div class="bg-ivory-50 p-4 border-t border-ivory-200">
                <div class="flex items-center justify-between text-sm">
                  <div class="flex items-center gap-1.5 text-navy-600">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    <span><%= event.location %></span>
                  </div>
                  <%= link_to "RSVP", "#", class: "font-semibold text-campaign-red hover:text-red-700" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>



<%# Host an Event CTA %>
<section class="bg-navy-900 text-white py-16 md:py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-display text-3xl md:text-4xl font-bold mb-4">Host a House Party</h2>
    <p class="text-navy-200 text-lg mb-8 mx-auto max-w-2xl">
      Interested in hosting a meet-and-greet or house party? We'd love to come speak to your group. It's a great way to introduce Andrew to your friends and neighbors.
    </p>
    <%= link_to "Learn More & Contact Us", volunteer_path, class: "bg-campaign-red hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors" %>
  </div>
</section>

