<% content_for :title, "Clough for SC5" %>

<%# Hero Section %>
<section class="bg-navy-900 w-full overflow-hidden">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row min-h-[600px] lg:min-h-[780px]">
    <div class="flex-1 flex flex-col justify-center px-6 py-12 lg:px-20">
      <div class="flex items-center gap-3 mb-7">
        <div class="bg-campaign-gold h-0.5 w-10"></div>
        <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.15em] uppercase">
          South Carolina District 5
        </span>
      </div>
      <h1 class="text-white font-display text-4xl sm:text-5xl lg:text-7xl font-bold leading-[1.05] mb-6">
        Enough<br class="hidden sm:block" /> is <br class="hidden sm:block" />Enough!
      </h1>
      <p class="text-slate-400 font-sans text-base sm:text-lg leading-relaxed mb-10 max-w-lg">
        Andrew Clough is running for South Carolina District 5 to put community first — bringing honest, accountable leadership back to Columbia.
      </p>
      <div class="flex flex-wrap gap-4">
        <%= link_to "Volunteer", volunteer_path, class: "bg-campaign-gold hover:bg-campaign-gold-dark text-white font-sans text-sm font-bold tracking-wider uppercase px-9 py-4 rounded transition-colors" %>
        <%= link_to "Donate", "https://secure.actblue.com/donate/andrew-clough-1", target: "_blank", rel: "noopener", class: "border border-white/30 hover:bg-white/10 text-white font-sans text-sm font-bold tracking-wider uppercase px-9 py-4 rounded transition-colors" %>
      </div>
    </div>
    <div class="hidden lg:flex items-end justify-center flex-shrink-0 w-[480px]">
      <%= image_tag 'home-hero-bg.jpg', class: "object-cover object-center [object-position:center_15%] rounded-t-lg h-[680px] w-full" %>
    </div>
  </div>
</section>

<%# About Section %>
<section class="bg-white w-full">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-8 lg:gap-[100px] px-6 py-16 lg:px-20 lg:py-[120px]">
    <div class="relative w-full sm:w-[360px] lg:w-[460px] flex-shrink-0">
      <%= image_tag 'home-about-bg.jpg', class: "rounded-lg w-full h-auto object-cover" %>
      <div class="absolute -bottom-4 -left-4 sm:-bottom-5 sm:-left-5 bg-navy-900 rounded flex flex-col items-center justify-center gap-1 w-24 h-24 lg:w-[120px] lg:h-[120px]">
        <span class="text-campaign-gold font-display text-2xl lg:text-3xl font-bold leading-tight">SC</span>
        <span class="text-white font-sans text-[9px] lg:text-[10px] font-semibold tracking-[0.1em] leading-tight">DISTRICT 5</span>
      </div>
    </div>
    <div class="flex-1">
      <div class="flex items-center gap-3 mb-5">
        <div class="bg-campaign-gold h-0.5 w-10"></div>
        <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.15em] uppercase">About Andrew</span>
      </div>
      <h2 class="text-navy-900 font-display text-3xl sm:text-4xl lg:text-[46px] font-bold leading-[1.1] mb-7">
        A neighbor.<br />A voice.<br />A leader.
      </h2>
      <p class="text-gray-600 font-sans text-base lg:text-lg leading-[1.8] mb-5">
        Andrew Clough has lived and worked in District 5 for over a decade. He understands the challenges families face because he faces them too — rising costs, underfunded schools, and a government that too often feels out of reach.
      </p>
      <p class="text-gray-600 font-sans text-base lg:text-lg leading-[1.8] mb-10">
        Andrew believes in transparent government, investing in education, and building an economy that works for everyone — not just those at the top.
      </p>
      <div class="flex flex-wrap gap-6 sm:gap-12">
        <div class="flex flex-col gap-1">
          <span class="text-campaign-gold font-display text-3xl lg:text-[36px] font-bold leading-tight">5+</span>
          <span class="text-gray-500 font-sans text-xs tracking-[0.08em] uppercase">Years in District 5</span>
        </div>
        <div class="hidden sm:block bg-gray-200 w-px"></div>
        <div class="flex flex-col gap-1">
          <span class="text-campaign-gold font-display text-3xl lg:text-[36px] font-bold leading-tight">5</span>
          <span class="text-gray-500 font-sans text-xs tracking-[0.08em] uppercase">Core Priorities</span>
        </div>
        <div class="hidden sm:block bg-gray-200 w-px"></div>
        <div class="flex flex-col gap-1">
          <span class="text-campaign-gold font-display text-3xl lg:text-[36px] font-bold leading-tight">1</span>
          <span class="text-gray-500 font-sans text-xs tracking-[0.08em] uppercase">Goal: Serve You</span>
        </div>
      </div>
    </div>
  </div>
</section>

<%# Issues Section %>
<section id="issues" class="bg-ivory-100 w-full">
  <div class="max-w-7xl mx-auto px-6 py-16 lg:px-20 lg:py-[120px]">
    <div class="flex flex-col items-center mb-12 lg:mb-16">
      <div class="flex items-center gap-3 mb-5">
        <div class="bg-campaign-gold h-0.5 w-10"></div>
        <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.15em] uppercase">The Issues</span>
        <div class="bg-campaign-gold h-0.5 w-10"></div>
      </div>
      <h2 class="text-navy-900 font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.1] mb-4 text-center">What Andrew Stands For</h2>
      <p class="text-gray-500 font-sans text-base lg:text-lg leading-relaxed max-w-lg text-center">Five priorities. One mission. A District 5 that works for the people who live here.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @active_issues.each do |issue| %>
        <a href="<%= issue_path(issue) %>" class="block bg-white rounded-lg border-t-4 <%= issue.featured? ? 'border-campaign-gold' : 'border-navy-900' %> p-8 lg:p-9 hover:shadow-lg transition-shadow no-underline text-inherit">
          <div class="bg-navy-900 rounded w-12 h-12 flex items-center justify-center mb-6">
            <% if issue.icon.present? %>
              <%= issue_icon(issue.icon) %>
            <% end %>
          </div>
          <h3 class="text-navy-900 font-display text-xl lg:text-2xl font-bold mb-3"><%= issue.title %></h3>
          <p class="text-gray-500 font-sans text-sm leading-[1.8] mb-5"><%= truncate(strip_tags(issue.description.to_s), length: 150) %></p>
          <div class="flex items-center gap-2 mt-auto">
            <div class="bg-campaign-gold h-0.5 w-6"></div>
            <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.1em] uppercase">Learn More</span>
          </div>
        </a>
      <% end %>
    </div>
  </div>
</section>

<%# Get Involved Section %>
<section class="bg-navy-900 w-full">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-8 lg:gap-[100px] px-6 py-16 lg:px-20 lg:py-[120px]">
    <div class="flex-1">
      <div class="flex items-center gap-3 mb-5">
        <div class="bg-campaign-gold h-0.5 w-10"></div>
        <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.15em] uppercase">Get Involved</span>
      </div>
      <h2 class="text-white font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.1] mb-6">Change starts with you.</h2>
      <p class="text-slate-400 font-sans text-base lg:text-lg leading-[1.8] mb-10">Campaigns are powered by people. Knock doors, make calls, share the word — every hour you give moves us closer to a District 5 that works for everyone.</p>
      <div class="flex flex-wrap gap-8 sm:gap-16">
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-3"><div class="bg-campaign-gold rounded-full w-2 h-2 flex-shrink-0"></div><span class="text-slate-300 font-sans text-base">Canvassing</span></div>
          <div class="flex items-center gap-3"><div class="bg-campaign-gold rounded-full w-2 h-2 flex-shrink-0"></div><span class="text-slate-300 font-sans text-base">Phone Banking</span></div>
          <div class="flex items-center gap-3"><div class="bg-campaign-gold rounded-full w-2 h-2 flex-shrink-0"></div><span class="text-slate-300 font-sans text-base">Events & Rallies</span></div>
        </div>
        <div class="flex flex-col gap-3">
          <div class="flex items-center gap-3"><div class="bg-campaign-gold rounded-full w-2 h-2 flex-shrink-0"></div><span class="text-slate-300 font-sans text-base">Social Media</span></div>
          <div class="flex items-center gap-3"><div class="bg-campaign-gold rounded-full w-2 h-2 flex-shrink-0"></div><span class="text-slate-300 font-sans text-base">Yard Signs</span></div>
          <div class="flex items-center gap-3"><div class="bg-campaign-gold rounded-full w-2 h-2 flex-shrink-0"></div><span class="text-slate-300 font-sans text-base">Fundraising</span></div>
        </div>
      </div>
    </div>
    <div class="w-full lg:w-[500px] bg-white rounded-lg p-6 sm:p-12 flex flex-col gap-5">
      <h3 class="text-navy-900 font-display text-2xl lg:text-[28px] font-bold mb-2">Join the Campaign</h3>
      <div class="flex flex-col sm:flex-row gap-4">
        <div class="flex-1 flex flex-col gap-2">
          <label class="text-gray-700 font-sans text-xs font-semibold uppercase">First Name</label>
          <input type="text" class="bg-gray-50 border border-gray-200 rounded h-12 px-3 w-full" />
        </div>
        <div class="flex-1 flex flex-col gap-2">
          <label class="text-gray-700 font-sans text-xs font-semibold uppercase">Last Name</label>
          <input type="text" class="bg-gray-50 border border-gray-200 rounded h-12 px-3 w-full" />
        </div>
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-gray-700 font-sans text-xs font-semibold uppercase">Email Address</label>
        <input type="email" class="bg-gray-50 border border-gray-200 rounded h-12 px-3 w-full" />
      </div>
      <div class="flex flex-col gap-2">
        <label class="text-gray-700 font-sans text-xs font-semibold uppercase">Zip Code</label>
        <input type="text" class="bg-gray-50 border border-gray-200 rounded h-12 px-3 w-full" />
      </div>
      <button class="bg-campaign-gold hover:bg-campaign-gold-dark text-white font-sans text-sm font-bold tracking-wider uppercase h-[52px] rounded transition-colors mt-2 w-full">
        Sign Me Up
      </button>
      <p class="text-gray-400 font-sans text-xs text-center">Your information is private and will never be sold.</p>
    </div>
  </div>
</section>

<%# Donate Section %>
<section id="donate" class="bg-campaign-gold w-full">
  <div class="max-w-7xl mx-auto flex flex-col items-center justify-center px-6 py-16 lg:px-20 lg:py-[100px]">
    <h2 class="text-white font-display text-3xl sm:text-4xl lg:text-[54px] font-bold leading-[1.1] mb-5 text-center">Fuel the Movement.</h2>
    <p class="text-white/85 font-sans text-base lg:text-lg leading-relaxed max-w-lg mb-10 text-center">Every dollar stays in District 5 — going toward outreach, events, and getting our message out to neighbors who are ready for real change.</p>
    <div class="flex flex-wrap justify-center gap-3 sm:gap-4 mb-10">
      <a href="https://secure.actblue.com/donate/andrew-clough-1?amount=25" target="_blank" rel="noopener" class="bg-white/20 border border-white/50 rounded px-6 sm:px-7 py-3 sm:py-4 text-white font-sans text-sm font-bold hover:bg-white/30 transition-colors">$25</a>
      <a href="https://secure.actblue.com/donate/andrew-clough-1?amount=50" target="_blank" rel="noopener" class="bg-white/20 border border-white/50 rounded px-6 sm:px-7 py-3 sm:py-4 text-white font-sans text-sm font-bold hover:bg-white/30 transition-colors">$50</a>
      <a href="https://secure.actblue.com/donate/andrew-clough-1?amount=100" target="_blank" rel="noopener" class="bg-white/20 border border-white/50 rounded px-6 sm:px-7 py-3 sm:py-4 text-white font-sans text-sm font-bold hover:bg-white/30 transition-colors">$100</a>
      <a href="https://secure.actblue.com/donate/andrew-clough-1?amount=250" target="_blank" rel="noopener" class="bg-white/20 border border-white/50 rounded px-6 sm:px-7 py-3 sm:py-4 text-white font-sans text-sm font-bold hover:bg-white/30 transition-colors">$250</a>
      <a href="https://secure.actblue.com/donate/andrew-clough-1" target="_blank" rel="noopener" class="bg-white/20 border border-white/50 rounded px-6 sm:px-7 py-3 sm:py-4 text-white font-sans text-sm font-bold hover:bg-white/30 transition-colors">Other</a>
    </div>
    <a href="https://secure.actblue.com/donate/andrew-clough-1" target="_blank" rel="noopener" class="bg-navy-900 hover:bg-navy-800 rounded px-14 py-4 text-white font-sans text-sm font-bold tracking-wider uppercase transition-colors">
      Donate Now
    </a>
  </div>
</section>
