<% content_for :title, "Clough for SC5" %>

<%# Hero Section %>
<div style="background-color: #0F2044; width: 100%; box-sizing: border-box;">
  <div style="max-width: 1440px; margin-inline: auto; display: flex; flex-shrink: 0; min-height: 780px; overflow: clip;">
    <div style="flex-basis: 0%; flex-grow: 1; flex-shrink: 1; display: flex; flex-direction: column; justify-content: center; padding-inline: 80px;">
      <div style="align-items: center; display: flex; gap: 12px; margin-bottom: 28px;">
        <div style="background-color: #C8902A; height: 2px; width: 40px;"></div>
        <div style="color: #C8902A; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase;">
          South Carolina District 5
        </div>
      </div>
      <div style="color: #FFFFFF; font-family: 'Playfair Display', serif; font-size: 74px; font-weight: 700; line-height: 1.05; margin-bottom: 24px; white-space: pre-wrap;">People<br />Over<br />Politics.</div>
      <div style="color: #94A3B8; font-family: 'Inter', sans-serif; font-size: 18px; line-height: 1.7; margin-bottom: 48px; max-width: 440px;">
        Andrew Clough is running for South Carolina District 5 to put community first — bringing honest, accountable leadership back to Columbia.
      </div>
      <div style="align-items: center; display: flex; gap: 16px;">
        <div style="background-color: #C8902A; border-radius: 4px; padding: 16px 36px;">
          <div style="color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;">
            Volunteer
          </div>
        </div>
        <div style="border: 1.5px solid rgba(255, 255, 255, 0.3); border-radius: 4px; padding: 16px 36px;">
          <div style="color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;">
            Donate
          </div>
        </div>
      </div>
    </div>
    <div style="align-items: flex-end; display: flex; flex-shrink: 0; justify-content: center; width: 560px;">
      <%= image_tag 'home-hero-bg.jpg', style: "object-fit: cover; object-position: center 15%; border-top-left-radius: 8px; border-top-right-radius: 8px; height: 680px; width: 480px;" %>
    </div>
  </div>
</div>

<%# About Section %>
<div style="background-color: #FFFFFF; width: 100%; box-sizing: border-box;">
  <div style="max-width: 1440px; margin-inline: auto; display: flex; align-items: center; gap: 100px; padding: 120px 80px;">
    <div style="height: 560px; position: relative; width: 460px; flex-shrink: 0;">
      <%= image_tag 'home-about-bg.jpg', style: "border-radius: 6px; height: 540px; width: 460px; object-fit: cover;" %>
      <div style="align-items: center; background-color: #0F2044; border-radius: 4px; bottom: 0; left: -20px; display: flex; flex-direction: column; gap: 4px; height: 120px; justify-content: center; position: absolute; width: 120px;">
        <div style="color: #C8902A; font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; line-height: 34px;">SC</div>
        <div style="color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.1em; line-height: 12px;">DISTRICT 5</div>
      </div>
    </div>
    <div style="flex-basis: 0%; flex-grow: 1; display: flex; flex-direction: column;">
      <div style="align-items: center; display: flex; gap: 12px; margin-bottom: 20px;">
        <div style="background-color: #C8902A; height: 2px; width: 40px;"></div>
        <div style="color: #C8902A; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase;">About Andrew</div>
      </div>
      <div style="color: #0F2044; font-family: 'Playfair Display', serif; font-size: 46px; font-weight: 700; line-height: 1.1; margin-bottom: 28px; white-space: pre-wrap;">A neighbor.<br />A voice.<br />A leader.</div>
      <div style="color: #4B5563; font-family: 'Inter', sans-serif; font-size: 17px; line-height: 1.8; margin-bottom: 20px;">Andrew Clough has lived and worked in District 5 for over a decade. He understands the challenges families face because he faces them too — rising costs, underfunded schools, and a government that too often feels out of reach.</div>
      <div style="color: #4B5563; font-family: 'Inter', sans-serif; font-size: 17px; line-height: 1.8; margin-bottom: 40px;">Andrew believes in transparent government, investing in education, and building an economy that works for everyone — not just those at the top.</div>
      <div style="display: flex; gap: 48px;">
        <div style="display: flex; flex-direction: column; gap: 4px;">
          <div style="color: #C8902A; font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 700; line-height: 44px;">10+</div>
          <div style="color: #6B7280; font-family: 'Inter', sans-serif; font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase;">Years in District 5</div>
        </div>
        <div style="background-color: #E5E7EB; width: 1px;"></div>
        <div style="display: flex; flex-direction: column; gap: 4px;">
          <div style="color: #C8902A; font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 700; line-height: 44px;">5</div>
          <div style="color: #6B7280; font-family: 'Inter', sans-serif; font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase;">Core Priorities</div>
        </div>
        <div style="background-color: #E5E7EB; width: 1px;"></div>
        <div style="display: flex; flex-direction: column; gap: 4px;">
          <div style="color: #C8902A; font-family: 'Playfair Display', serif; font-size: 36px; font-weight: 700; line-height: 44px;">1</div>
          <div style="color: #6B7280; font-family: 'Inter', sans-serif; font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase;">Goal: Serve You</div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Issues Section %>
<div id="issues" style="background-color: #F5F4F1; width: 100%; box-sizing: border-box;">
  <div style="max-width: 1440px; margin-inline: auto; padding: 120px 80px;">
    <div style="display: flex; align-items: center; flex-direction: column; margin-bottom: 60px;">
      <div style="align-items: center; display: flex; gap: 12px; margin-bottom: 20px;">
        <div style="background-color: #C8902A; height: 2px; width: 40px;"></div>
        <div style="color: #C8902A; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase;">The Issues</div>
        <div style="background-color: #C8902A; height: 2px; width: 40px;"></div>
      </div>
      <div style="color: #0F2044; font-family: 'Playfair Display', serif; font-size: 50px; font-weight: 700; line-height: 1.1; margin-bottom: 16px; text-align: center;">What Andrew Stands For</div>
      <div style="color: #6B7280; font-family: 'Inter', sans-serif; font-size: 17px; line-height: 1.7; max-width: 560px; text-align: center;">Five priorities. One mission. A District 5 that works for the people who live here.</div>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;">
      <% @active_issues.each do |issue| %>
        <a href="<%= issue_path(issue) %>" style="text-decoration: none; color: inherit; background-color: #FFFFFF; border-radius: 8px; border-top: 4px solid <%= issue.featured? ? '#C8902A' : '#0F2044' %>; padding: 40px 36px; display: flex; flex-direction: column; transition: box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,0.1)'" onmouseout="this.style.boxShadow='none'">
          <div style="align-items: center; background-color: #0F2044; border-radius: 6px; display: flex; height: 48px; justify-content: center; margin-bottom: 24px; width: 48px; flex-shrink: 0;">
            <% if issue.icon.present? %>
              <%= issue_icon(issue.icon) %>
            <% end %>
          </div>
          <div style="color: #0F2044; font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 700; margin-bottom: 12px;"><%= issue.title %></div>
          <div style="color: #6B7280; font-family: 'Inter', sans-serif; font-size: 14px; line-height: 1.8; flex-grow: 1;"><%= truncate(strip_tags(issue.description.to_s), length: 150) %></div>
          <div style="align-items: center; display: flex; gap: 8px; margin-top: 20px;">
            <div style="background-color: #C8902A; height: 2px; width: 24px;"></div>
            <div style="color: #C8902A; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;">Learn More</div>
          </div>
        </a>
      <% end %>
    </div>
  </div>
</div>

<%# Get Involved Section %>
<div style="background-color: #0F2044; width: 100%; box-sizing: border-box;">
  <div style="max-width: 1440px; margin-inline: auto; display: flex; align-items: center; gap: 100px; padding: 120px 80px;">
    <div style="flex-basis: 0%; flex-grow: 1; flex-shrink: 1; display: flex; flex-direction: column;">
      <div style="align-items: center; display: flex; gap: 12px; margin-bottom: 20px;">
        <div style="background-color: #C8902A; height: 2px; width: 40px;"></div>
        <div style="color: #C8902A; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase;">Get Involved</div>
      </div>
      <div style="color: #FFFFFF; font-family: 'Playfair Display', serif; font-size: 50px; font-weight: 700; line-height: 1.1; margin-bottom: 24px;">Change starts with you.</div>
      <div style="color: #94A3B8; font-family: 'Inter', sans-serif; font-size: 17px; line-height: 1.8; margin-bottom: 48px;">Campaigns are powered by people. Knock doors, make calls, share the word — every hour you give moves us closer to a District 5 that works for everyone.</div>
      <div style="display: flex; gap: 32px;">
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <div style="align-items: center; display: flex; gap: 10px;"><div style="background-color: #C8902A; border-radius: 50%; height: 8px; width: 8px; flex-shrink: 0;"></div><div style="color: #CBD5E1; font-family: 'Inter', sans-serif; font-size: 15px;">Canvassing</div></div>
          <div style="align-items: center; display: flex; gap: 10px;"><div style="background-color: #C8902A; border-radius: 50%; height: 8px; width: 8px; flex-shrink: 0;"></div><div style="color: #CBD5E1; font-family: 'Inter', sans-serif; font-size: 15px;">Phone Banking</div></div>
          <div style="align-items: center; display: flex; gap: 10px;"><div style="background-color: #C8902A; border-radius: 50%; height: 8px; width: 8px; flex-shrink: 0;"></div><div style="color: #CBD5E1; font-family: 'Inter', sans-serif; font-size: 15px;">Events & Rallies</div></div>
        </div>
        <div style="display: flex; flex-direction: column; gap: 8px;">
          <div style="align-items: center; display: flex; gap: 10px;"><div style="background-color: #C8902A; border-radius: 50%; height: 8px; width: 8px; flex-shrink: 0;"></div><div style="color: #CBD5E1; font-family: 'Inter', sans-serif; font-size: 15px;">Social Media</div></div>
          <div style="align-items: center; display: flex; gap: 10px;"><div style="background-color: #C8902A; border-radius: 50%; height: 8px; width: 8px; flex-shrink: 0;"></div><div style="color: #CBD5E1; font-family: 'Inter', sans-serif; font-size: 15px;">Yard Signs</div></div>
          <div style="align-items: center; display: flex; gap: 10px;"><div style="background-color: #C8902A; border-radius: 50%; height: 8px; width: 8px; flex-shrink: 0;"></div><div style="color: #CBD5E1; font-family: 'Inter', sans-serif; font-size: 15px;">Fundraising</div></div>
        </div>
      </div>
    </div>
    <div style="background-color: #FFFFFF; border-radius: 8px; padding: 48px; width: 500px; flex-shrink: 0; display: flex; flex-direction: column; gap: 20px;">
      <div style="color: #0F2044; font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; margin-bottom: 8px;">Join the Campaign</div>
      <div style="display: flex; gap: 16px;">
        <div style="flex-grow: 1; display: flex; flex-direction: column; gap: 8px;">
          <div style="color: #374151; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; text-transform: uppercase;">First Name</div>
          <div style="background-color: #F9FAFB; border: 1.5px solid #E5E7EB; border-radius: 4px; height: 48px;"></div>
        </div>
        <div style="flex-grow: 1; display: flex; flex-direction: column; gap: 8px;">
          <div style="color: #374151; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; text-transform: uppercase;">Last Name</div>
          <div style="background-color: #F9FAFB; border: 1.5px solid #E5E7EB; border-radius: 4px; height: 48px;"></div>
        </div>
      </div>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <div style="color: #374151; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; text-transform: uppercase;">Email Address</div>
        <div style="background-color: #F9FAFB; border: 1.5px solid #E5E7EB; border-radius: 4px; height: 48px;"></div>
      </div>
      <div style="display: flex; flex-direction: column; gap: 8px;">
        <div style="color: #374151; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; text-transform: uppercase;">Zip Code</div>
        <div style="background-color: #F9FAFB; border: 1.5px solid #E5E7EB; border-radius: 4px; height: 48px;"></div>
      </div>
      <div style="align-items: center; background-color: #C8902A; border-radius: 4px; display: flex; height: 52px; justify-content: center; margin-top: 8px;">
        <div style="color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;">Sign Me Up</div>
      </div>
      <div style="color: #9CA3AF; font-family: 'Inter', sans-serif; font-size: 12px; text-align: center;">Your information is private and will never be sold.</div>
    </div>
  </div>
</div>

<%# Donate Section %>
<div style="background-color: #C8902A; width: 100%; box-sizing: border-box;">
  <div style="max-width: 1440px; margin-inline: auto; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 100px 80px;">
    <div style="color: #FFFFFF; font-family: 'Playfair Display', serif; font-size: 54px; font-weight: 700; line-height: 1.1; margin-bottom: 20px; text-align: center;">Fuel the Movement.</div>
    <div style="color: rgba(255,255,255,0.85); font-family: 'Inter', sans-serif; font-size: 18px; line-height: 1.7; margin-bottom: 48px; max-width: 560px; text-align: center;">Every dollar stays in District 5 — going toward outreach, events, and getting our message out to neighbors who are ready for real change.</div>
    <div style="display: flex; gap: 16px; margin-bottom: 48px;">
      <div style="background-color: rgba(255,255,255,0.2); border: 1.5px solid rgba(255,255,255,0.5); border-radius: 4px; padding: 14px 28px;">
        <div style="color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700;">$25</div>
      </div>
      <div style="background-color: rgba(255,255,255,0.2); border: 1.5px solid rgba(255,255,255,0.5); border-radius: 4px; padding: 14px 28px;">
        <div style="color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700;">$50</div>
      </div>
      <div style="background-color: rgba(255,255,255,0.2); border: 1.5px solid rgba(255,255,255,0.5); border-radius: 4px; padding: 14px 28px;">
        <div style="color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700;">$100</div>
      </div>
      <div style="background-color: rgba(255,255,255,0.2); border: 1.5px solid rgba(255,255,255,0.5); border-radius: 4px; padding: 14px 28px;">
        <div style="color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700;">$250</div>
      </div>
      <div style="background-color: rgba(255,255,255,0.2); border: 1.5px solid rgba(255,255,255,0.5); border-radius: 4px; padding: 14px 28px;">
        <div style="color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700;">Other</div>
      </div>
    </div>
    <div style="background-color: #0F2044; border-radius: 4px; padding: 18px 60px;">
      <div style="color: #FFFFFF; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;">Donate Now</div>
    </div>
  </div>
</div>
