
<%# Hero Section %>
<section class="bg-navy-900 w-full overflow-hidden">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row min-h-[600px] lg:min-h-[780px]">
    <div class="flex-1 flex flex-col justify-center px-6 py-12 lg:px-20">
      <div class="flex items-center gap-3 mb-7">
        <div class="bg-campaign-gold h-0.5 w-10"></div>
        <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.15em] uppercase">
          South Carolina District 5
        </span>
      </div>
      <h1 class="text-white font-display text-4xl sm:text-5xl lg:text-7xl font-bold leading-[1.05] mb-6">
        Enough<br class="hidden sm:block" /> is <br class="hidden sm:block" />Enough!
      </h1>
      <p class="text-slate-400 font-sans text-base sm:text-lg leading-relaxed mb-10 max-w-lg">
        Andrew Clough is running for South Carolina District 5 to put community first — bringing honest, accountable leadership back to Columbia.
      </p>
      <div class="flex flex-wrap gap-4">
        <%= link_to "Volunteer", volunteer_path, class: "bg-campaign-gold hover:bg-campaign-gold-dark text-white font-sans text-sm font-bold tracking-wider uppercase px-9 py-4 rounded transition-colors" %>
        <%= link_to "Donate", "https://secure.actblue.com/donate/andrew-clough-1", target: "_blank", rel: "noopener", class: "border border-white/30 hover:bg-white/10 text-white font-sans text-sm font-bold tracking-wider uppercase px-9 py-4 rounded transition-colors" %>
      </div>
    </div>
    <div class="hidden lg:flex items-end justify-center flex-shrink-0 w-[480px]">
      <%= image_tag 'home-hero-bg.jpg', class: "object-cover object-center [object-position:center_15%] rounded-t-lg h-[680px] w-full" %>
    </div>
  </div>
</section>

<%# About Section %>
<section class="bg-white w-full">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-8 lg:gap-[100px] px-6 py-16 lg:px-20 lg:py-[120px]">
    <div class="relative w-full sm:w-[360px] lg:w-[460px] flex-shrink-0">
      <%= image_tag 'home-about-bg.jpg', class: "rounded-lg w-full h-auto object-cover" %>
      <div class="absolute -bottom-4 -left-4 sm:-bottom-5 sm:-left-5 bg-navy-900 rounded flex flex-col items-center justify-center gap-1 w-24 h-24 lg:w-[120px] lg:h-[120px]">
        <span class="text-campaign-gold font-display text-2xl lg:text-3xl font-bold leading-tight">SC</span>
        <span class="text-white font-sans text-[9px] lg:text-[10px] font-semibold tracking-[0.1em] leading-tight">DISTRICT 5</span>
      </div>
    </div>
    <div class="flex-1">
      <div class="flex items-center gap-3 mb-5">
        <div class="bg-campaign-gold h-0.5 w-10"></div>
        <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.15em] uppercase">About Andrew</span>
      </div>
      <h2 class="text-navy-900 font-display text-3xl sm:text-4xl lg:text-[46px] font-bold leading-[1.1] mb-7">
        A neighbor.<br />A voice.<br />A leader.
      </h2>
      <p class="text-gray-600 font-sans text-base lg:text-lg leading-[1.8] mb-5">
        I'm Andrew Clough. A proud stepfather, dedicated airline worker, and community advocate. Though I wasn't raised in the Carolinas, I chose to build my life and family here in South Carolina's 5th District because I believe in its people, its promise, and its future.
      </p>
      <p class="text-gray-600 font-sans text-base lg:text-lg leading-[1.8] mb-10">
        I'm not a career politician, I'm one of us. I've worked hard, faced challenges, and I know what it means to fight for a better life. I'm running for Congress because we need leadership that listens, serves, and acts with compassion and courage.
      </p>
      <p class="text-gray-600 font-sans text-base lg:text-lg leading-[1.8] mb-10">
        My campaign is rooted in one idea: People Over Politics. That means putting working families, veterans, small businesses, and our communities first, always.
      </p>
      <div class="flex flex-wrap gap-6 sm:gap-12">
        <div class="flex flex-col gap-1">
          <span class="text-campaign-gold font-display text-3xl lg:text-[36px] font-bold leading-tight">5+</span>
          <span class="text-gray-500 font-sans text-xs tracking-[0.08em] uppercase">Years in District 5</span>
        </div>
        <div class="hidden sm:block bg-gray-200 w-px"></div>
        <div class="flex flex-col gap-1">
          <span class="text-campaign-gold font-display text-3xl lg:text-[36px] font-bold leading-tight">5</span>
          <span class="text-gray-500 font-sans text-xs tracking-[0.08em] uppercase">Core Priorities</span>
        </div>
        <div class="hidden sm:block bg-gray-200 w-px"></div>
        <div class="flex flex-col gap-1">
          <span class="text-campaign-gold font-display text-3xl lg:text-[36px] font-bold leading-tight">1</span>
          <span class="text-gray-500 font-sans text-xs tracking-[0.08em] uppercase">Goal: Serve You</span>
        </div>
      </div>
    </div>
  </div>
</section>

<%# Priorities Section %>
<section id="priorities" class="bg-ivory-100 w-full">
  <div class="max-w-7xl mx-auto px-6 py-16 lg:px-20 lg:py-[120px]">
    <div class="flex flex-col items-center mb-12 lg:mb-16">
      <div class="flex items-center gap-3 mb-5">
        <div class="bg-campaign-gold h-0.5 w-10"></div>
        <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.15em] uppercase">Core Priorities</span>
        <div class="bg-campaign-gold h-0.5 w-10"></div>
      </div>
      <h2 class="text-navy-900 font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.1] mb-4 text-center">What Andrew Stands For</h2>
      <p class="text-gray-500 font-sans text-base lg:text-lg leading-relaxed max-w-lg text-center">Five priorities. One mission. A District 5 that works for the people who live here.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @priorities.each do |priority| %>
        <% card_tag = priority.linked_issue ? "a" : "div" %>
        <% card_href = priority.linked_issue ? issue_path(priority.linked_issue) : nil %>
        <% card_class = "block bg-white rounded-lg border-t-4 border-campaign-gold p-8 lg:p-9 hover:shadow-lg transition-shadow no-underline text-inherit" %>

        <% if priority.linked_issue %>
          <a href="<%= card_href %>" class="<%= card_class %>">
        <% else %>
          <div class="<%= card_class %>">
        <% end %>
          <% if priority.show_icon? && priority.icon.present? %>
            <div class="bg-navy-900 rounded w-12 h-12 flex items-center justify-center mb-6">
              <%= issue_icon(priority.icon) %>
            </div>
          <% end %>
          <h3 class="text-navy-900 font-display text-xl lg:text-2xl font-bold mb-3"><%= priority.title %></h3>
          <% if priority.description.present? %>
            <p class="text-gray-500 font-sans text-sm leading-[1.8] mb-5"><%= priority.description %></p>
          <% end %>
          <% if priority.linked_issue %>
            <div class="flex items-center gap-2 mt-auto">
              <div class="bg-campaign-gold h-0.5 w-6"></div>
              <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.1em] uppercase">Learn More</span>
            </div>
          <% end %>
        <% if priority.linked_issue %>
          </a>
        <% else %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</section>

<%# Endorsements Section %>
<% if @endorsers.any? %>
<section class="bg-white w-full">
  <div class="max-w-7xl mx-auto px-6 py-16 lg:px-20 lg:py-[100px]">
    <div class="flex flex-col items-center mb-12 lg:mb-16">
      <div class="flex items-center gap-3 mb-5">
        <div class="bg-campaign-gold h-0.5 w-10"></div>
        <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.15em] uppercase">Endorsements</span>
        <div class="bg-campaign-gold h-0.5 w-10"></div>
      </div>
      <h2 class="text-navy-900 font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.1] mb-4 text-center">Trusted by Our Community</h2>
      <p class="text-gray-500 font-sans text-base lg:text-lg leading-relaxed max-w-lg text-center">Leaders and neighbors across District 5 are backing Andrew Clough.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @endorsers.each do |endorser| %>
        <div class="bg-ivory-50 rounded-lg p-8 border border-ivory-200 hover:shadow-lg transition-shadow">
          <div class="flex items-center gap-4 mb-5">
            <% if endorser.photo_url.present? %>
              <img src="<%= endorser.photo_url %>" alt="<%= endorser.name %>" class="w-14 h-14 rounded-full object-cover flex-shrink-0">
            <% else %>
              <div class="w-14 h-14 rounded-full bg-navy-900 flex items-center justify-center flex-shrink-0">
                <span class="text-campaign-gold font-display text-xl font-bold"><%= endorser.name.first.upcase %></span>
              </div>
            <% end %>
            <div>
              <h3 class="text-navy-900 font-display text-lg font-bold leading-tight"><%= endorser.name %></h3>
              <% if endorser.title.present? %>
                <p class="text-gray-500 font-sans text-sm"><%= endorser.title %></p>
              <% end %>
            </div>
          </div>
          <p class="text-gray-600 font-sans text-sm leading-[1.8] italic">"<%= endorser.quote %>"</p>
          <% if endorser.category.present? %>
            <div class="mt-4 pt-4 border-t border-ivory-200">
              <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.08em] uppercase"><%= endorser.category %></span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<%# Get Involved Section %>
<section class="bg-navy-900 w-full">
  <div class="max-w-7xl mx-auto flex flex-col lg:flex-row items-center gap-8 lg:gap-[100px] px-6 py-16 lg:px-20 lg:py-[120px]">
