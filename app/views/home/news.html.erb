
<%# Hero Section %>
<div class="bg-navy-900 text-white py-16 md:py-24 bg-cover bg-center" style="background-image: url(<%= image_path 'news-hero-bg.jpg' %>);">
  <div class="bg-navy-900 bg-opacity-80 py-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-5xl md:text-6xl font-bold mb-4">
        Campaign News
      </h1>
      <p class="text-xl text-navy-200 max-w-2xl mx-auto">
        The latest updates from the campaign trail and news from around District 5.
      </p>
    </div>
  </div>
</div>

<%# Featured Article %>
<% if @featured_article %>
<section class="py-16 md:py-24 bg-ivory-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-2 lg:order-1">
        <div class="aspect-w-16 aspect-h-9 rounded-xl overflow-hidden shadow-lg">
          <%= image_tag 'featured-article.jpg', class: "w-full h-full object-cover" %>
        </div>
      </div>
      <div class="order-1 lg:order-2">
        <p class="text-campaign-red font-semibold tracking-wider uppercase mb-4">Featured Story</p>
        <h2 class="font-display text-4xl font-bold text-navy-900 mb-4">
          <%= @featured_article.title %>
        </h2>
        <p class="text-navy-600 text-lg mb-6">
          <%= @featured_article.body %>
        </p>
        <div class="flex items-center gap-4 text-sm text-navy-500 mb-8">
          <span><%= @featured_article.source %></span>
          <span>&bull;</span>
          <span><%= @featured_article.published_date.strftime("%B %d, %Y") %></span>
        </div>
        <%= link_to "Read Full Story", "#", class: "bg-campaign-red hover:bg-red-700 text-white px-8 py-4 rounded-lg font-semibold transition-colors" %>
      </div>
    </div>
  </div>
</section>
<% end %>

<%# Articles Grid %>
<section class="py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="font-display text-4xl font-bold text-navy-900">Latest News</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @articles.each_with_index do |article, index| %>
        <div class="bg-white border border-ivory-200 rounded-xl shadow-sm hover:shadow-lg transition-shadow overflow-hidden flex flex-col">
          <%= image_tag "news-article-#{index + 1}.jpg", class: "w-full h-48 object-cover" %>
          <div class="p-6 flex-grow flex flex-col">
            <h3 class="font-display text-xl font-bold text-navy-900 mb-3 flex-grow"><%= article.title %></h3>
            <div class="text-sm text-navy-500">
              <span><%= article.source %></span>
              <span>&bull;</span>
              <span><%= article.published_date.strftime("%B %d, %Y") %></span>
            </div>
          </div>
          <%= link_to "Read More", "#", class: "bg-ivory-50 text-navy-700 font-semibold text-sm py-3 px-6 text-center hover:bg-ivory-100 transition-colors" %>
        </div>
      <% end %>
    </div>
    
    <div class="text-center mt-16">
      <a href="#" class="bg-navy-800 hover:bg-navy-900 text-white px-8 py-4 rounded-lg font-semibold transition-colors">Load More Articles</a>
    </div>
  </div>
</section>