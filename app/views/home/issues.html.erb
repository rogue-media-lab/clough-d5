<% content_for :title, "Issues - Clough for SC5" %>

<%# Hero Section %>
<section class="bg-navy-900 w-full">
  <div class="max-w-7xl mx-auto px-6 py-16 lg:px-20 lg:py-16 flex flex-col gap-4">
    <div class="flex items-center gap-3">
      <div class="bg-campaign-gold h-8 w-[3px]"></div>
      <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.1em] uppercase">Where Andrew Stands</span>
    </div>
    <h1 class="text-white font-display text-4xl sm:text-5xl lg:text-[52px] font-bold leading-[1.15]">The Issues</h1>
    <p class="text-white/70 font-sans text-base lg:text-lg leading-relaxed max-w-lg">District 5 deserves a representative who shows up with a plan, not talking points. Here's where Andrew stands — and what he'll fight for in Congress.</p>
  </div>
</section>

<%# Issues Grid %>
<section class="bg-ivory-50 w-full">
  <div class="max-w-7xl mx-auto px-6 py-16 lg:px-20 lg:pb-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @issues.each do |issue| %>
        <a href="<%= issue_path(issue) %>" class="bg-white rounded-lg border-t-4 border-campaign-gold p-8 lg:p-9 flex flex-col gap-4 hover:shadow-lg transition-shadow no-underline text-inherit">
          <div class="flex items-center gap-4">
            <div class="bg-ivory-100 rounded-lg w-11 h-11 flex items-center justify-center flex-shrink-0">
              <% if issue.icon.present? %>
                <%= issue_icon(issue.icon) %>
              <% else %>
                <div class="bg-campaign-gold rounded w-5 h-5"></div>
              <% end %>
            </div>
            <h2 class="text-navy-900 font-display text-xl lg:text-2xl font-bold"><%= issue.title %></h2>
          </div>
          <p class="text-gray-500 font-sans text-base leading-relaxed flex-1">
            <% if issue.tagline.present? %>
              <%= issue.tagline %>
            <% else %>
              <%= truncate(strip_tags(issue.description.to_s), length: 180) %>
            <% end %>
          </p>
          <span class="text-campaign-gold font-sans text-sm font-medium mt-auto">Read more →</span>
        </a>
      <% end %>
    </div>

    <% if @issues.empty? %>
      <div class="text-center py-20">
        <p class="text-gray-400 font-sans text-lg">No issues have been published yet. Check back soon.</p>
      </div>
    <% end %>
  </div>
</section>
