<% content_for :title, "#{@issue.title} - Clough for SC5" %>

<%# Hero Section %>
<section class="bg-navy-900 w-full">
  <div class="max-w-7xl mx-auto px-6 py-16 lg:px-20 lg:py-16 flex flex-col gap-4">
    <div class="flex items-center gap-3">
      <div class="bg-campaign-gold h-8 w-[3px]"></div>
      <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.1em] uppercase">Where Andrew Stands</span>
    </div>
    <div class="flex items-center gap-4 flex-wrap">
      <% if @issue.icon.present? %>
        <div class="bg-campaign-gold/15 rounded-xl w-14 h-14 flex items-center justify-center">
          <%= issue_icon(@issue.icon) %>
        </div>
      <% end %>
      <h1 class="text-white font-display text-3xl sm:text-4xl lg:text-[48px] font-bold leading-[1.15]"><%= @issue.title %></h1>
    </div>
  </div>
</section>

<%# Content Section %>
<section class="bg-ivory-50 w-full">
  <div class="max-w-5xl mx-auto px-6 py-16 lg:px-20 lg:py-16">
    <a href="<%= issues_path %>" class="text-campaign-gold font-sans text-sm font-medium hover:underline mb-10 inline-block">← Back to All Issues</a>

    <div class="flex flex-col lg:flex-row gap-10 lg:gap-16 items-start">
      <%# Main content %>
      <div class="flex-1 min-w-0">
        <% if @issue.tagline.present? %>
          <div class="border-l-4 border-campaign-gold pl-6 mb-9">
            <p class="text-gray-700 font-display text-xl italic leading-relaxed">"<%= @issue.tagline %>"</p>
          </div>
        <% end %>

        <div class="prose prose-lg text-gray-700 font-sans text-lg leading-[1.8]">
          <%= @issue.description %>
        </div>

        <div class="border-t border-gray-200 mt-12 pt-10 flex justify-center">
          <%= link_to "Help Fight for This →", volunteer_path, class: "bg-campaign-gold hover:bg-campaign-gold-dark text-white font-sans text-base font-semibold px-9 py-3.5 rounded-lg transition-colors inline-block" %>
        </div>
      </div>

      <%# Sidebar %>
      <% if @issue.summary.present? %>
        <div class="w-full lg:w-[340px] bg-sky-50 rounded-xl p-7 lg:p-8 flex-shrink-0">
          <h3 class="text-navy-900 font-display text-xl font-bold mb-5">Platform at a Glance</h3>
          <ul class="flex flex-col gap-4 list-none p-0 m-0">
            <% @issue.summary.each_line.map(&:strip).reject(&:blank?).each do |line| %>
              <% if line.include?(":") %>
                <% label, desc = line.split(":", 2) %>
                <li class="flex gap-2.5 items-start">
                  <span class="text-campaign-gold text-xs mt-1.5 flex-shrink-0">●</span>
                  <span>
                    <strong class="text-navy-900 font-sans text-sm font-semibold"><%= label.strip %>:</strong>
                    <span class="text-gray-600 font-sans text-sm leading-relaxed"><%= desc.strip %></span>
                  </span>
                </li>
              <% else %>
                <li class="flex gap-2.5 items-start">
                  <span class="text-campaign-gold text-xs mt-1.5 flex-shrink-0">●</span>
                  <span class="text-gray-600 font-sans text-sm leading-relaxed"><%= line %></span>
                </li>
              <% end %>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </div>
</section>
