      <div style="border-color: rgba(255, 255, 255, 0.3); border-radius: 4px; border-style: solid; border-width: 1.5px; box-sizing: border-box; padding-block: 16px; padding-inline: 40px;">
        <div style="box-sizing: border-box; color: #FFFFFF; font-family: 'Inter', system-ui, sans-serif; font-size: 15px; font-weight: 600; line-height: 18px; text-align: center;">
