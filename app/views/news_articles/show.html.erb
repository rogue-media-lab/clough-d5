<% content_for :title, "#{@article.title} | Clough for SC5" %>

<%# Article Header %>
<section class="bg-navy-900 w-full">
  <div class="max-w-5xl mx-auto px-6 py-10 lg:px-20 lg:py-16">
    <%= link_to news_path, class: "inline-flex items-center gap-2 text-slate-400 hover:text-white font-sans text-sm transition-colors mb-6 no-underline" do %>
      <span>&larr;</span> Back to News
    <% end %>
    <div class="flex items-center gap-3 mb-4">
      <span class="text-xs font-semibold tracking-[0.1em] uppercase text-campaign-gold"><%= @article.source %></span>
      <% if @article.featured? %>
        <span class="text-campaign-gold text-sm">&#9733; Featured</span>
      <% end %>
    </div>
    <h1 class="text-white font-display text-2xl sm:text-3xl lg:text-4xl font-bold leading-[1.15] mb-4"><%= @article.title %></h1>
    <div class="flex items-center gap-4 text-slate-400 font-sans text-sm">
      <% if @article.published_date.present? %>
        <span><%= @article.published_date.strftime("%B %-d, %Y") %></span>
      <% end %>
      <% if @article.external_url.present? %>
        <span>&middot;</span>
        <a href="<%= @article.external_url %>" target="_blank" rel="noopener" class="text-campaign-gold hover:text-white transition-colors">Open original &rarr;</a>
      <% end %>
    </div>
  </div>
</section>

<%# Article Body + Embedded View %>
<section class="bg-white w-full">
  <div class="max-w-5xl mx-auto px-6 py-10 lg:px-20">
    <% if @article.body.present? %>
      <div class="mb-8">
        <p class="text-gray-600 font-sans text-base lg:text-lg leading-[1.8]"><%= @article.body %></p>
      </div>
    <% end %>

    <%# Embedded Article Frame %>
    <% if @article.external_url.present? %>
      <div class="rounded-xl overflow-hidden border border-gray-200 relative" style="height: 75vh; min-height: 500px;">
        <iframe
          id="article-frame"
          src="<%= @article.external_url %>"
          class="w-full h-full border-0"
          sandbox="allow-scripts allow-same-origin"
          loading="lazy"
          referrerpolicy="no-referrer"
        ></iframe>
        <%# Fallback if iframe is blocked %>
        <div id="iframe-fallback" class="hidden absolute inset-0 bg-ivory-100 flex flex-col items-center justify-center text-center p-8">
          <div class="bg-white rounded-xl border border-gray-200 p-10 max-w-md">
            <div class="w-16 h-16 bg-navy-900 rounded-full flex items-center justify-center mx-auto mb-6">
              <span class="text-campaign-gold text-2xl">&#128279;</span>
            </div>
            <h3 class="text-navy-900 font-display text-xl font-bold mb-3">This article can't be displayed here</h3>
            <p class="text-gray-500 font-sans text-sm leading-relaxed mb-6">
              <%= @article.source %> doesn't allow their pages to be embedded. You can read the full article on their site.
            </p>
            <a href="<%= @article.external_url %>" target="_blank" rel="noopener"
               class="inline-block bg-campaign-gold hover:bg-campaign-gold-dark text-white font-sans text-sm font-bold tracking-wider uppercase px-8 py-3 rounded transition-colors no-underline">
              Read on <%= @article.source %> &rarr;
            </a>
          </div>
        </div>
      </div>
      <script>
        // Detect if iframe fails to load (blocked by X-Frame-Options)
        const frame = document.getElementById('article-frame');
        const fallback = document.getElementById('iframe-fallback');
        let loaded = false;

        frame.addEventListener('load', () => {
          loaded = true;
          try {
            // Try to access iframe content — will throw if blocked by CORS/X-Frame-Options
            const url = frame.contentWindow.location.href;
            if (url === 'about:blank') {
              fallback.classList.remove('hidden');
            }
          } catch(e) {
            // Cross-origin — but iframe loaded, so it's fine
          }
        });

        frame.addEventListener('error', () => {
          fallback.classList.remove('hidden');
        });

        // Safety timeout — show fallback if nothing loads in 8s
        setTimeout(() => {
          if (!loaded) {
            fallback.classList.remove('hidden');
          }
        }, 8000);
      </script>
    <% end %>

    <%# Related Articles %>
    <% if @related.any? %>
      <div class="mt-12">
        <div class="flex items-center gap-3 mb-6">
          <div class="bg-campaign-gold h-0.5 w-10"></div>
          <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.15em] uppercase">More from <%= @article.source %></span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <% @related.each do |related| %>
            <%= link_to news_article_path(related), class: "block bg-ivory-100 rounded-lg p-5 hover:shadow-md transition-shadow no-underline" do %>
              <h4 class="text-navy-900 font-display text-sm font-bold leading-[1.3] mb-2"><%= related.title %></h4>
              <span class="text-gray-400 font-sans text-xs"><%= related.published_date&.strftime("%b %-d, %Y") %></span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
