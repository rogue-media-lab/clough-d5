<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
  <div class="w-full max-w-md bg-white border border-gray-200 rounded-lg shadow-sm px-8 py-10">
    <h1 class="text-2xl font-bold text-navy-900 mb-8 text-center">Sign in</h1>

    <%= form_with url: session_path do |form| %>
      <div class="space-y-5">

        <div>
          <%= form.label :email_address, "Email", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.email_field :email_address,
                required: true,
                autofocus: true,
                autocomplete: "username",
                class: "w-full px-3 py-2 border border-gray-300 rounded-md text-navy-900 placeholder-gray-400 bg-white focus:outline-none focus:ring-2 focus:ring-navy-400 focus:border-transparent text-sm" %>
        </div>

        <div data-controller="password-toggle">
          <%= form.label :password, "Password", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <div class="flex items-center gap-2">
            <%= form.password_field :password,
                  required: true,
                  autocomplete: "current-password",
                  data: { password_toggle_target: "input" },
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md text-navy-900 placeholder-gray-400 bg-white focus:outline-none focus:ring-2 focus:ring-navy-400 focus:border-transparent text-sm" %>
            <button type="button"
                    data-action="click->password-toggle#toggle"
                    class="flex-shrink-0 text-gray-400 hover:text-gray-600 transition-colors p-1 cursor-pointer"
                    tabindex="-1">
              <!-- Eye open (visible) - Heroicons -->
              <svg data-password-toggle-target="eyeOpen" class="hidden w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              </svg>
              <!-- Eye closed (hidden) - Heroicons -->
              <svg data-password-toggle-target="eyeClosed" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c1.691 0 3.252-.432 4.616-1.192M6.625 6.623A10.45 10.45 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 0 1-4.293 5.774M6.625 6.623 3 3m3.625 3.623 11.25 11.25"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="flex justify-end">
          <%= link_to "Forgot password?", new_password_path,
                class: "text-sm text-gray-500 hover:text-navy-900 transition-colors" %>
        </div>

        <%= form.submit "Sign in", class: "w-full bg-navy-900 hover:bg-navy-800 text-white font-medium py-2 px-4 rounded-md transition-colors cursor-pointer text-sm" %>

      </div>
    <% end %>
  </div>
</div>
