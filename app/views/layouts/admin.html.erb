<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:page_title) ? yield(:page_title) : "Admin" %> | Clough for SC5</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      .sidebar-link { display: block; padding: 10px 16px; border-radius: 8px; color: #CBD5E1; font-size: 14px; font-weight: 500; text-decoration: none; transition: background-color 0.15s; }
      .sidebar-link:hover { background-color: rgba(255,255,255,0.1); color: #FFFFFF; }
      .sidebar-link.active { background-color: #C8902A; color: #FFFFFF; font-weight: 600; }
      .sidebar-heading { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: #64748B; padding: 16px 16px 8px; }
      .stat-card { background: #FFFFFF; border-radius: 8px; border: 1px solid #E5E7EB; padding: 20px; }
      .stat-label { font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 500; color: #6B7280; text-transform: uppercase; margin-bottom: 4px; }
      .stat-value { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; color: #0F2044; }
      .widget-card { background: #FFFFFF; border-radius: 8px; border: 1px solid #E5E7EB; }
      .widget-header { padding: 14px 20px; border-bottom: 1px solid #E5E7EB; display: flex; justify-content: space-between; align-items: center; }
      .widget-title { font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; color: #374151; margin: 0; }
      .widget-link { font-family: 'Inter', sans-serif; font-size: 12px; color: #6B7280; text-decoration: none; }
      .widget-link:hover { color: #0F2044; }
      .widget-row { padding: 12px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #F3F4F6; }
      .widget-row:last-child { border-bottom: none; }
      .badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; }
      .badge-confirmed { background: #DCFCE7; color: #166534; }
      .badge-contacted { background: #DBEAFE; color: #1E40AF; }
      .badge-pending { background: #FEF3C7; color: #92400E; }
    </style>
  </head>
  <body class="font-sans">
    <div style="display: flex; height: 100vh;">
      <!-- Sidebar -->
      <aside style="width: 260px; background-color: #0F2044; display: flex; flex-direction: column; flex-shrink: 0; color: #FFFFFF; overflow-y: auto;">
        <div style="display: flex; align-items: center; gap: 12px; padding: 24px 20px; margin-bottom: 8px;">
          <div style="width: 36px; height: 36px; border-radius: 50%; border: 2px solid #C8902A; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <div style="width: 10px; height: 10px; border-radius: 50%; background-color: #C8902A;"></div>
          </div>
          <div>
            <div style="color: #FFFFFF; font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 700; line-height: 1.2;">Clough for SC5</div>
            <div style="color: #94A3B8; font-size: 11px;">Campaign Dashboard</div>
          </div>
        </div>

        <nav style="flex: 1; padding: 0 12px;">
          <div class="sidebar-heading">Overview</div>
          <%= link_to admin_root_path, class: "sidebar-link #{request.path == admin_root_path ? 'active' : ''}" do %>
            <span style="margin-right: 8px;">📊</span> Dashboard
          <% end %>

          <div class="sidebar-heading">Content</div>
          <%= link_to admin_issues_path, class: "sidebar-link #{request.path.starts_with?(admin_issues_path) ? 'active' : ''}" do %>
            <span style="margin-right: 8px;">📋</span> Issues
          <% end %>
          <%= link_to admin_priorities_path, class: "sidebar-link #{request.path.starts_with?(admin_priorities_path) ? 'active' : ''}" do %>
            <span style="margin-right: 8px;">🎯</span> Priorities
          <% end %>
          <%= link_to admin_posts_path, class: "sidebar-link #{request.path.starts_with?(admin_posts_path) ? 'active' : ''}" do %>
            <span style="margin-right: 8px;">📝</span> Blog
          <% end %>
          <%= link_to admin_news_articles_path, class: "sidebar-link #{request.path.starts_with?(admin_news_articles_path) ? 'active' : ''}" do %>
            <span style="margin-right: 8px;">📰</span> News
          <% end %>
          <%= link_to admin_news_feeds_path, class: "sidebar-link #{request.path.starts_with?(admin_news_feeds_path) ? 'active' : ''}" do %>
            <span style="margin-right: 8px;">📡</span> RSS Feeds
          <% end %>
          <%= link_to admin_events_path, class: "sidebar-link #{request.path.starts_with?(admin_events_path) ? 'active' : ''}" do %>
            <span style="margin-right: 8px;">📅</span> Events
          <% end %>
          <%= link_to admin_endorsers_path, class: "sidebar-link #{request.path.starts_with?(admin_endorsers_path) ? 'active' : ''}" do %>
            <span style="margin-right: 8px;">⭐</span> Endorsements
          <% end %>

          <div class="sidebar-heading">People</div>
          <%= link_to admin_contact_messages_path, class: "sidebar-link #{request.path.starts_with?(admin_contact_messages_path) ? 'active' : ''}" do %>
            <span style="margin-right: 8px;">✉️</span> Messages
            <% unread = ContactMessage.unread.count %>
            <% if unread > 0 %>
              <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 20px; height: 20px; padding: 0 6px; border-radius: 10px; background: #DC2626; color: #FFFFFF; font-size: 11px; font-weight: 700; margin-left: 8px;"><%= unread %></span>
            <% end %>
          <% end %>
          <%= link_to admin_volunteer_submissions_path, class: "sidebar-link #{request.path.starts_with?(admin_volunteer_submissions_path) ? 'active' : ''}" do %>
            <span style="margin-right: 8px;">🙋</span> Volunteers
          <% end %>
          <%= link_to admin_volunteer_interests_path, class: "sidebar-link #{request.path.starts_with?(admin_volunteer_interests_path) ? 'active' : ''}" do %>
            <span style="margin-right: 8px;">🏷️</span> Interest Categories
          <% end %>
        </nav>

        <div style="padding: 16px 20px; border-top: 1px solid #1E2D4A;">
          <p style="font-size: 12px; color: #94A3B8; margin: 0;"><%= Current.user.email_address %></p>
          <%= button_to "Sign out", session_path(Current.session), method: :delete, class: "w-full text-left text-sm text-slate-400 hover:text-white mt-2" %>
        </div>
      </aside>

      <!-- Main content -->
      <div style="flex: 1; background-color: #F9F8F6; overflow-y: auto;">
        <header style="display: flex; justify-content: space-between; align-items: center; padding: 24px 40px; border-bottom: 1px solid #E5E7EB; background: #FFFFFF;">
          <div>
            <h1 style="font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 700; color: #0F2044; margin: 0;"><%= content_for(:page_title) %></h1>
            <% if content_for?(:page_subtitle) %>
              <p style="font-family: 'Inter', sans-serif; font-size: 14px; color: #6B7280; margin: 4px 0 0;"><%= yield(:page_subtitle) %></p>
            <% end %>
          </div>
        </header>
        <main style="padding: 32px 40px;">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
