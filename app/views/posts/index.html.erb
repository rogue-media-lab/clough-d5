<% content_for :title, "News | Clough for SC5" %>

<%# News Articles Section (Primary) %>
<section class="bg-navy-900 w-full">
  <div class="max-w-7xl mx-auto px-6 py-16 lg:px-20 lg:py-[80px]">
    <div class="flex items-center gap-3 mb-5">
      <div class="bg-campaign-gold h-0.5 w-10"></div>
      <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.15em] uppercase">In The News</span>
    </div>
    <h2 class="text-white font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.1] mb-4">Andrew Clough in the Media</h2>
    <p class="text-slate-400 font-sans text-base lg:text-lg leading-relaxed mb-10">Coverage and stories from around District 5 and beyond.</p>

    <% if @news_articles.any? %>
      <% featured_article = @news_articles.detect(&:featured?) %>
      <% remaining_articles = @news_articles.reject { |a| a == featured_article } %>

      <%# Featured Article Hero %>
      <% if featured_article %>
        <div class="bg-white/5 border border-white/10 rounded-xl overflow-hidden mb-8">
          <div class="p-8 lg:p-12 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xs font-semibold tracking-[0.1em] uppercase text-campaign-gold"><%= featured_article.source %></span>
              <% if featured_article.featured? %>
                <span class="text-campaign-gold text-sm">&#9733;</span>
              <% end %>
            </div>
            <h3 class="text-white font-display text-2xl lg:text-3xl font-bold leading-[1.2] mb-4">
              <% if featured_article.external_url.present? %>
                <a href="<%= featured_article.external_url %>" target="_blank" class="hover:text-campaign-gold transition-colors"><%= featured_article.title %></a>
              <% else %>
                <%= featured_article.title %>
              <% end %>
            </h3>
            <% if featured_article.body.present? %>
              <p class="text-slate-400 font-sans text-base leading-[1.8] mb-6 max-w-2xl"><%= featured_article.body.truncate(200) %></p>
            <% end %>
            <div class="flex items-center gap-6">
              <% if featured_article.published_date.present? %>
                <span class="text-slate-500 font-sans text-sm"><%= featured_article.published_date.strftime("%B %-d, %Y") %></span>
              <% end %>
              <% if featured_article.external_url.present? %>
                <a href="<%= featured_article.external_url %>" target="_blank" class="inline-flex items-center gap-2 text-campaign-gold font-sans text-sm font-semibold tracking-wider uppercase hover:text-white transition-colors">
                  Read Full Article
                  <span>&rarr;</span>
                </a>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <%# Article Grid %>
      <% if remaining_articles.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% remaining_articles.each do |article| %>
            <div class="bg-white/5 border border-white/10 rounded-xl p-6 lg:p-7 hover:bg-white/10 transition-colors">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-xs font-semibold tracking-[0.1em] uppercase text-campaign-gold"><%= article.source %></span>
                <% if article.featured? %>
                  <span class="text-campaign-gold text-sm">&#9733;</span>
                <% end %>
              </div>
              <h4 class="text-white font-display text-lg font-bold leading-[1.3] mb-3">
                <% if article.external_url.present? %>
                  <a href="<%= article.external_url %>" target="_blank" class="hover:text-campaign-gold transition-colors"><%= article.title %></a>
                <% else %>
                  <%= article.title %>
                <% end %>
              </h4>
              <% if article.body.present? %>
                <p class="text-slate-400 font-sans text-sm leading-[1.7] mb-4"><%= article.body.truncate(120) %></p>
              <% end %>
              <div class="flex items-center justify-between mt-auto pt-3 border-t border-white/5">
                <span class="text-slate-500 font-sans text-xs"><%= article.published_date&.strftime("%b %-d, %Y") %></span>
                <% if article.external_url.present? %>
                  <a href="<%= article.external_url %>" target="_blank" class="text-campaign-gold font-sans text-xs font-semibold tracking-wider uppercase hover:text-white transition-colors">Read &rarr;</a>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <p class="text-slate-500 font-sans text-base">No news coverage yet. Check back soon.</p>
    <% end %>
  </div>
</section>

<%# Blog Posts Section (Secondary) %>
<section class="bg-white w-full">
  <div class="max-w-7xl mx-auto px-6 py-16 lg:px-20 lg:py-[80px]">
    <div class="flex items-center gap-3 mb-5">
      <div class="bg-campaign-gold h-0.5 w-10"></div>
      <span class="text-campaign-gold font-sans text-xs font-semibold tracking-[0.15em] uppercase">From the Campaign</span>
    </div>
    <h2 class="text-navy-900 font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.1] mb-4">Campaign Updates</h2>
    <p class="text-gray-500 font-sans text-base lg:text-lg leading-relaxed mb-10">The latest from Andrew and the team.</p>

    <% if @featured_post || @posts.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <%# Featured Post First %>
        <% if @featured_post %>
          <div class="bg-navy-900 rounded-xl overflow-hidden lg:col-span-2 lg:row-span-2 flex flex-col">
            <% if @featured_post.cover_image.attached? %>
              <%= image_tag @featured_post.cover_image, class: "w-full h-48 lg:h-full object-cover flex-shrink-0" %>
            <% end %>
            <div class="p-6 lg:p-8 flex flex-col flex-1">
              <span class="text-xs font-semibold tracking-[0.1em] uppercase text-campaign-gold mb-3">Featured</span>
              <h3 class="text-white font-display text-xl lg:text-2xl font-bold leading-[1.2] mb-3">
                <%= link_to @featured_post.title, post_path(@featured_post), class: "hover:text-campaign-gold transition-colors" %>
              </h3>
              <% if @featured_post.subtitle.present? %>
                <p class="text-slate-400 font-sans text-sm leading-[1.7] mb-4"><%= @featured_post.subtitle.truncate(120) %></p>
              <% end %>
              <div class="mt-auto">
                <span class="text-slate-500 font-sans text-xs"><%= @featured_post.published_at&.strftime("%b %-d, %Y") %></span>
              </div>
            </div>
          </div>
        <% end %>

        <%# Post Cards %>
        <% @posts.each do |post| %>
          <div class="bg-ivory-100 rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
            <% if post.cover_image.attached? %>
              <%= link_to post_path(post) do %>
                <%= image_tag post.cover_image, class: "w-full h-40 object-cover" %>
              <% end %>
            <% end %>
            <div class="p-6">
              <span class="text-gray-400 font-sans text-xs"><%= post.published_at&.strftime("%b %-d, %Y") %></span>
              <h4 class="text-navy-900 font-display text-base font-bold leading-[1.3] mt-2 mb-3">
                <%= link_to post.title, post_path(post), class: "hover:text-campaign-gold transition-colors no-underline text-navy-900" %>
              </h4>
              <% if post.subtitle.present? %>
                <p class="text-gray-500 font-sans text-sm leading-[1.7] mb-3"><%= post.subtitle.truncate(100) %></p>
              <% end %>
              <%= link_to "Read &rarr;".html_safe, post_path(post), class: "text-campaign-gold font-sans text-xs font-semibold tracking-wider uppercase hover:text-navy-900 transition-colors no-underline" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 font-sans text-base">No posts published yet.</p>
    <% end %>
  </div>
</section>
